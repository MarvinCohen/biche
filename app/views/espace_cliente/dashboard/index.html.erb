<% content_for :title, "Mon espace" %>

<%#
  ============================================================
  VUE — Espace cliente (dashboard unique avec 5 onglets JS)
  Onglets : Fidélité / Mes RDV / Historique / Messages / Profil
  Données chargées par EspaceCliente::DashboardController#index
  @fidelite_card chargé par BaseController (set_fidelite_card)
  ============================================================
%>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <%# Bouton de déconnexion Devise (méthode DELETE sur la session) %>
        <%= link_to "Déconnexion",
                    destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "logout-btn" %>
        <div class="burger"><span></span><span></span><span></span></div>
      </div>
    </nav>

    <%# ---- HERO PROFIL — avatar + nom + stats rapides ---- %>
    <div class="profile-hero">
      <%# Cercle avec l'initiale du prénom de la cliente %>
      <div class="avatar"><%= current_user.initiale %></div>

      <div class="profile-name"><%= current_user.full_name %></div>
      <div class="profile-since">
        Cliente depuis <%= I18n.l(current_user.created_at.to_date, format: "%B %Y") %>
      </div>

      <%# Stats résumées : visites totales / points actifs / prochain RDV %>
      <div class="profile-stats">
        <div class="profile-stat">
          <span class="profile-stat-num"><%= @fidelite_card.visites %></span>
          <span class="profile-stat-label">Visites</span>
        </div>
        <div class="profile-stat">
          <span class="profile-stat-num"><%= @fidelite_card.points_cycle_actuel %></span>
          <span class="profile-stat-label">Points</span>
        </div>
        <div class="profile-stat">
          <%# Nombre total de RDV à venir %>
          <span class="profile-stat-num"><%= @rdvs_a_venir.size %></span>
          <span class="profile-stat-label">Prochain RDV</span>
        </div>
      </div>
    </div>

    <%# ---- BARRE DE NAVIGATION INTERNE — 5 onglets scrollables ---- %>
    <div class="client-nav">
      <div class="client-nav-inner">
        <%# Chaque bouton affiche un onglet via showTab() défini en bas de page %>
        <button class="client-nav-item active" onclick="showTab('fidelite', this)">Fidélité</button>
        <button class="client-nav-item" onclick="showTab('rdv', this)">Mes RDV</button>
        <button class="client-nav-item" onclick="showTab('historique', this)">Historique</button>
        <%# Badge rouge si messages non lus %>
        <button class="client-nav-item" onclick="showTab('messages', this)">
          Messages
          <% if @messages_non_lus_count > 0 %>
            <span class="nl-count-badge"><%= @messages_non_lus_count %></span>
          <% end %>
        </button>
        <button class="client-nav-item" onclick="showTab('profil', this)">Mon profil</button>
      </div>
    </div>

    <%# ================================================================
        ONGLET 1 — FIDÉLITÉ
        Carte de fidélité + statistiques du programme
    ================================================================= %>
    <div id="tab-fidelite">
      <div class="sec">
        <p class="s-tag">Programme</p>
        <h2 class="s-h2">Carte fidélité</h2>

        <%# Carte visuelle style "carte de fidélité" %>
        <div class="fidelite-card">
          <div class="fid-top">
            <div class="fid-logo">Biche.</div>
            <div>
              <div class="fid-prog-label">Progression</div>
              <%# X / 10 — points dans le cycle actuel %>
              <div class="fid-prog-num">
                <%= @fidelite_card.points_cycle_actuel %> / <%= FideliteCard::VISITES_POUR_RECOMPENSE %>
              </div>
            </div>
          </div>

          <%# 10 points représentés par des cercles (remplis = visites validées) %>
          <div class="fid-dots">
            <% FideliteCard::VISITES_POUR_RECOMPENSE.times do |i| %>
              <% if i == FideliteCard::VISITES_POUR_RECOMPENSE - 1 %>
                <%# Dernier cercle = étoile (récompense) %>
                <div class="fid-dot star">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="rgba(255,255,255,0.4)">
                    <path d="M5 1l1.2 2.5 2.8.4-2 2 .5 2.8L5 7.4 2.5 8.7l.5-2.8-2-2 2.8-.4z"/>
                  </svg>
                </div>
              <% elsif i < @fidelite_card.points_cycle_actuel %>
                <%# Cercle rempli = visite déjà faite %>
                <div class="fid-dot filled">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M2 5 L4 7 L8 3" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
              <% else %>
                <%# Cercle vide = visite à venir %>
                <div class="fid-dot"></div>
              <% end %>
            <% end %>
          </div>

          <%# Barre de progression (largeur dynamique en %) %>
          <div class="fid-progress-bar">
            <div class="fid-progress-fill" style="width: <%= @fidelite_card.progression_pourcent %>%"></div>
          </div>

          <div class="fid-bottom">
            <div class="fid-next">
              Encore <b><%= @fidelite_card.points_restants %> visites</b> pour une pose offerte
            </div>
          </div>
        </div>

        <%# Statistiques en grille 2×2 %>
        <div class="fid-stats">
          <div class="fid-stat-card">
            <span class="fid-stat-num"><%= @fidelite_card.visites %></span>
            <div class="fid-stat-label">Visites totales</div>
          </div>
          <div class="fid-stat-card">
            <span class="fid-stat-num"><%= @fidelite_card.points_cycle_actuel %></span>
            <div class="fid-stat-label">Points actifs</div>
          </div>
          <div class="fid-stat-card">
            <span class="fid-stat-num"><%= @fidelite_card.recompenses_utilisees %></span>
            <div class="fid-stat-label">Récompenses utilisées</div>
          </div>
          <div class="fid-stat-card">
            <span class="fid-stat-num"><%= @fidelite_card.points_restants %></span>
            <div class="fid-stat-label">Points restants</div>
          </div>
        </div>
      </div>

      <%# ============================================================
          BLOC CRÉDITS DE PACK — visible uniquement si la cliente en a.
          Preview de 3 crédits max + CTA vers la page dédiée /espace_cliente/credits.
          Affiché dans l'onglet Fidélité car les 2 sont des "avantages cliente".
      ============================================================ %>
      <% if @credits_actifs_count > 0 %>
        <div class="sec sec-cream">
          <p class="s-tag">Packs</p>
          <h2 class="s-h2">
            Mes crédits
            <%# Compteur entre parenthèses pour montrer le total tout de suite %>
            <span style="font-size:0.6em; color: var(--color-muted, #8e8480); font-family: 'Jost', sans-serif; font-weight: 400;">
              (<%= @credits_actifs_count %>)
            </span>
          </h2>

          <%# Liste compacte des 3 premiers crédits actifs (FIFO sur expiration) %>
          <% @credits_actifs_preview.each do |credit| %>
            <%# Mini-card horizontale : compteur à gauche, infos pose à droite %>
            <div class="rdv-card" style="margin-bottom: 10px;">
              <%# Pastille épurée : juste le gros chiffre des remplissages restants,
                  centré dans le carré sombre. La classe `credit-pill-solo` agrandit
                  le chiffre et garantit un centrage parfait (la pastille .rdv-date
                  était dimensionnée pour 2 lignes — on adapte pour 1 seule). %>
              <div class="rdv-date credit-pill-solo">
                <span class="credit-pill-solo-num"><%= credit.nb_restant %></span>
              </div>
              <div class="rdv-info">
                <div class="rdv-name"><%= credit.prestation.nom %></div>
                <%# Info principale : compteur explicite en toutes lettres %>
                <div class="rdv-time">
                  <strong><%= credit.nb_restant %> sur <%= credit.nb_total %></strong> remplissages restants
                </div>
                <%# Date d'expiration en dessous, plus discrète %>
                <div class="rdv-time" style="font-size: 11px; color: var(--color-muted, #8e8480); margin-top: 2px;">
                  Valable jusqu'au <%= I18n.l(credit.date_expiration, format: "%d %B %Y") %>
                </div>
              </div>
            </div>
          <% end %>

          <%# CTA vers la page complète des crédits (incl. l'historique) %>
          <div style="margin-top: 14px; text-align: center;">
            <%= link_to "Voir tous mes crédits →",
                        espace_cliente_credits_path,
                        class: "btn-ghost" %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ================================================================
        ONGLET 2 — MES RDV
        Tous les rendez-vous à venir (confirmés + en attente)
    ================================================================= %>
    <div id="tab-rdv" style="display:none">

      <div class="sec">
        <p class="s-tag">À venir</p>
        <h2 class="s-h2">Mes rendez-vous</h2>

        <% if @rdvs_a_venir.any? %>
          <%# On itère sur tous les RDV à venir triés par date %>
          <% @rdvs_a_venir.each do |rdv| %>
            <div class="rdv-card">
              <div class="rdv-date">
                <div class="rdv-day"><%= rdv.date.day %></div>
                <div class="rdv-month"><%= I18n.l(rdv.date, format: "%b") %></div>
              </div>
              <div class="rdv-info">
                <div class="rdv-name"><%= rdv.prestation.nom %></div>
                <div class="rdv-time">
                  <%= I18n.l(rdv.date, format: "%A").capitalize %> ·
                  <%= rdv.heure.strftime('%Hh%M') %>
                  <% if rdv.heure_fin %>
                    → <%= rdv.heure_fin.strftime('%Hh%M') %>
                  <% end %>
                </div>
                <div class="rdv-tags">
                  <span class="rdv-tag">Calao Studio</span>
                  <span class="rdv-tag"><%= rdv.prestation.duree_formatee %></span>
                  <%# Badge statut : vert si confirmé, neutre si en attente %>
                  <span class="rdv-tag" style="<%= rdv.statut == 'confirme' ? 'background:#e8f5e8;color:#4a7a4a;border-color:#c8e6c8;' : '' %>">
                    <%= rdv.statut == 'confirme' ? 'Confirmé' : 'En attente' %>
                  </span>
                </div>
              </div>
            </div>

            <%# Bouton annulation par RDV %>
            <div style="margin-bottom:16px;">
              <%= link_to "Annuler ce rendez-vous",
                          booking_path(rdv),
                          data: { turbo_method: :delete, turbo_confirm: "Annuler ce rendez-vous du #{I18n.l(rdv.date, format: '%d %B %Y')} ?" },
                          class: "btn-rdv-cancel" %>
            </div>
          <% end %>

        <% else %>
          <%# Aucun RDV à venir %>
          <div class="rdv-empty">
            <p class="rdv-empty-text">Vous n'avez pas de rendez-vous à venir pour le moment.</p>
            <%= link_to "Réserver un soin →", new_booking_path, class: "btn-primary" %>
          </div>
        <% end %>
      </div>

      <div class="sec" style="background: var(--color-nude);">
        <p class="s-tag">Nouveau</p>
        <h2 class="s-h2">Prendre rendez-vous</h2>
        <div class="rdv-empty">
          <p class="rdv-empty-text">Vous avez besoin d'un remplissage ? Réservez votre prochain créneau directement en ligne.</p>
          <%= link_to "Réserver un soin →", new_booking_path, class: "btn-primary" %>
        </div>
      </div>

    </div>

    <%# ================================================================
        ONGLET 3 — HISTORIQUE DES SOINS + ACHATS BOUTIQUE
        Liste accordéon de tous les soins terminés avec note de Syam,
        suivie d'une section regroupant les achats boutique (cartes cadeaux,
        packs de remplissages, produits routine).
    ================================================================= %>
    <div id="tab-historique" style="display:none">
      <%# ---- Soins passés ---- %>
      <div class="sec">
        <p class="s-tag">Suivi</p>
        <h2 class="s-h2">Historique des soins</h2>

        <% if @historique.any? %>
          <%# `collapsed` n'est appliqué que s'il y a plus de 3 soins : sinon
              tout est déjà visible et le bouton "Voir plus" n'apparaît pas. %>
          <div class="history-list <%= 'collapsed' if @historique.size > 3 %>">
            <% @historique.each do |booking| %>
              <%# Carte accordéon — cliquer sur le header ouvre les détails %>
              <div class="history-card">
                <div class="history-header" onclick="toggleHistory(this)">
                  <div class="history-left">
                    <div class="history-name"><%= booking.prestation.nom %></div>
                    <div class="history-date">
                      <%= I18n.l(booking.date, format: "%d %B %Y") %> ·
                      <%= booking.prestation.categorie.capitalize %>
                    </div>
                  </div>
                  <div class="history-right">
                    <div class="history-price">
                      <%= number_to_currency(booking.prestation.prix_euros, unit: "€", format: "%n%u", precision: 0) %>
                    </div>
                    <%# Flèche qui pivote à 180° quand la carte est ouverte %>
                    <div class="history-toggle">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M2 4 L6 8 L10 4" stroke="#2e2926" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </div>
                  </div>
                </div>

                <%# Détails cachés — visibles si la carte a la classe "open" %>
                <div class="history-details">
                  <% if booking.soin_historique %>
                    <%# Grille 2×2 des paramètres techniques du soin %>
                    <div class="detail-grid">
                      <% if booking.soin_historique.courbure.present? %>
                        <div class="detail-item">
                          <div class="detail-label">Courbure</div>
                          <div class="detail-value"><%= booking.soin_historique.courbure %></div>
                        </div>
                      <% end %>
                      <% if booking.soin_historique.longueur.present? %>
                        <div class="detail-item">
                          <div class="detail-label">Longueur</div>
                          <div class="detail-value"><%= booking.soin_historique.longueur %></div>
                        </div>
                      <% end %>
                      <% if booking.soin_historique.epaisseur.present? %>
                        <div class="detail-item">
                          <div class="detail-label">Épaisseur</div>
                          <div class="detail-value"><%= booking.soin_historique.epaisseur %></div>
                        </div>
                      <% end %>
                      <% if booking.soin_historique.technique.present? %>
                        <div class="detail-item">
                          <div class="detail-label">Technique</div>
                          <div class="detail-value"><%= booking.soin_historique.technique %></div>
                        </div>
                      <% end %>
                    </div>

                    <%# Note textuelle de Syam — colonne "note_syam" dans le schéma (pas "notes") %>
                    <% if booking.soin_historique.note_syam.present? %>
                      <div class="detail-note">
                        <div class="detail-note-label">Note de Syam</div>
                        <div class="detail-note-text"><%= booking.soin_historique.note_syam %></div>
                      </div>
                    <% end %>
                  <% end %>

                  <%# Bouton pour réserver le même soin %>
                  <%= link_to "Reprendre cette pose →",
                              new_booking_path(prestation_id: booking.prestation_id),
                              class: "history-rdv-btn" %>
                </div>
              </div>
            <% end %>
          </div>

          <%# Bouton "Voir plus" — affiché seulement si > 3 soins.
              Le JS toggleMore() retire la classe `collapsed` sur la liste précédente
              et met à jour le label + la flèche. %>
          <% if @historique.size > 3 %>
            <button class="history-show-more" onclick="toggleMore(this)" data-count="<%= @historique.size - 3 %>">
              <span>Voir les <%= @historique.size - 3 %> autres</span>
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          <% end %>
        <% else %>
          <%# Aucun soin terminé pour l'instant %>
          <div class="rdv-empty">
            <p class="rdv-empty-text">Votre historique apparaîtra ici après votre premier rendez-vous.</p>
            <%= link_to "Réserver un soin →", new_booking_path, class: "btn-primary" %>
          </div>
        <% end %>
      </div>

      <%# ---- Achats boutique (cartes cadeaux, packs, produits routine) ----
           Affiché seulement si la cliente a au moins un achat payé.
           On réutilise les classes .history-card pour la cohérence visuelle,
           avec la classe `open` pour que les détails soient visibles directement
           (peu d'infos à révéler → pas d'accordéon ici). %>
      <% if @achats.any? %>
        <div class="sec sec-cream">
          <p class="s-tag">Boutique</p>
          <h2 class="s-h2">Mes achats</h2>

          <%# Limité à 3 achats visibles par défaut + bouton "Voir plus" si >3
              pour éviter une liste trop longue. %>
          <div class="history-list <%= 'collapsed' if @achats.size > 3 %>">
            <% @achats.each do |order| %>
              <div class="history-card open">

                <%# En-tête : produit + montant (pas d'onclick → cursor: default) %>
                <div class="history-header" style="cursor: default;">
                  <div class="history-left">
                    <div class="history-name"><%= order.product.nom %></div>
                    <div class="history-date">
                      <%# Date d'achat en français — created_at car pas de "date d'achat" dédiée %>
                      <%= I18n.l(order.created_at.to_date, format: "%-d %B %Y") %>
                      ·
                      <%# Type lisible : carte cadeau / pack / routine / autre %>
                      <% case order.product.type_produit
                         when 'carte_cadeau' %>Carte cadeau<% when 'pack' %>Pack remplissages<% when 'routine' %>Routine<% else %>Boutique<% end %>
                    </div>
                  </div>
                  <div class="history-right">
                    <div class="history-price"><%= order.montant_euros.to_i %>€</div>
                  </div>
                </div>

                <%# Détails — variables selon le type de produit %>
                <div class="history-details">

                  <% if order.product.type_produit == 'carte_cadeau' && order.cartes_cadeaux.any? %>
                    <%# Carte cadeau : code à offrir + solde restant %>
                    <% carte = order.cartes_cadeaux.first %>
                    <div class="detail-grid">
                      <div class="detail-item">
                        <div class="detail-label">Code</div>
                        <%# code_lisible : helper du modèle CarteCadeau (sinon .code brut) %>
                        <div class="detail-value"><%= carte.respond_to?(:code_lisible) ? carte.code_lisible : carte.code %></div>
                      </div>
                      <div class="detail-item">
                        <div class="detail-label">Solde restant</div>
                        <div class="detail-value"><%= (carte.solde_cents / 100).to_i %>€</div>
                      </div>
                    </div>

                  <% elsif order.product.type_produit == 'pack' && @credit_par_order[order.id].present? %>
                    <%# Pack de remplissages : nb restant / total + date d'expiration %>
                    <% credit = @credit_par_order[order.id] %>
                    <div class="detail-grid">
                      <div class="detail-item">
                        <div class="detail-label">Restant</div>
                        <%# affichage_restant retourne "X/Y" — méthode du modèle Credit %>
                        <div class="detail-value"><%= credit.affichage_restant %></div>
                      </div>
                      <div class="detail-item">
                        <div class="detail-label">Pose</div>
                        <div class="detail-value"><%= credit.prestation&.nom || "—" %></div>
                      </div>
                      <% if credit.date_expiration.present? %>
                        <div class="detail-item">
                          <div class="detail-label">Expire le</div>
                          <div class="detail-value"><%= I18n.l(credit.date_expiration, format: "%-d %b %Y") %></div>
                        </div>
                      <% end %>
                    </div>

                  <% else %>
                    <%# Produit routine ou autre : juste la description courte si dispo %>
                    <% if order.product.description.present? %>
                      <p style="font-size: 12px; color: var(--color-muted); padding: 4px 0 8px; line-height: 1.5;">
                        <%= order.product.description %>
                      </p>
                    <% end %>
                  <% end %>
                </div>

              </div>
            <% end %>
          </div>

          <%# Bouton "Voir plus" pour les achats — même mécanique que pour les soins. %>
          <% if @achats.size > 3 %>
            <button class="history-show-more" onclick="toggleMore(this)" data-count="<%= @achats.size - 3 %>">
              <span>Voir les <%= @achats.size - 3 %> autres</span>
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# ================================================================
        ONGLET 4 — MESSAGES
        Newsletters, offres, rappels RDV, message d'anniversaire
    ================================================================= %>
    <div id="tab-messages" style="display:none">
      <div class="sec">
        <p class="s-tag">Communications</p>
        <h2 class="s-h2">Mes messages</h2>

        <% if @messages.any? %>
          <div class="newsletter-list">
            <% @messages.each do |message| %>
              <%# Classe CSS de l'icône selon le type de message %>
              <% icon_class = case message.type_message
                              when "anniversaire" then "nl-icon-birthday"
                              when "promo"        then "nl-icon-promo"
                              when "rappel_rdv"   then "nl-icon-promo"
                              else "nl-icon-news"
                              end %>

              <div class="newsletter-item">
                <%# Icône ronde colorée selon le type %>
                <div class="nl-icon <%= icon_class %>">
                  <% if message.type_message == "anniversaire" %>
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M3 10 L15 10 L14 16 L4 16 Z" stroke="#2e2926" stroke-width="1.2"/>
                      <path d="M9 10 L9 16" stroke="#2e2926" stroke-width="1"/>
                      <path d="M6 10 C6 8 7 6 9 6 C11 6 12 8 12 10" stroke="#2e2926" stroke-width="1.2"/>
                      <circle cx="9" cy="3.5" r="1" fill="#2e2926"/>
                    </svg>
                  <% else %>
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <rect x="3" y="4" width="12" height="10" rx="2" stroke="rgba(255,255,255,0.8)" stroke-width="1.2"/>
                      <path d="M6 8 L12 8 M6 11 L10 11" stroke="rgba(255,255,255,0.8)" stroke-width="1" stroke-linecap="round"/>
                    </svg>
                  <% end %>
                </div>

                <div class="nl-content">
                  <div class="nl-title"><%= message.titre %></div>
                  <div class="nl-date"><%= I18n.l(message.created_at.to_date, format: "%d %B %Y") %></div>
                </div>

                <%# Badge "Nouveau" si non lu, "Lu" si déjà ouvert %>
                <span class="nl-badge <%= message.lu ? 'read' : '' %>">
                  <%= message.lu ? "Lu" : "Nouveau" %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p style="font-size:13px;color:var(--color-muted);text-align:center;padding:24px 0;">
            Aucun message pour le moment.
          </p>
        <% end %>
      </div>
    </div>

    <%# ================================================================
        ONGLET 5 — MON PROFIL
        Informations personnelles + lien vers modification Devise
    ================================================================= %>
    <div id="tab-profil" style="display:none">

      <div class="sec">
        <p class="s-tag">Compte</p>
        <h2 class="s-h2">Mon profil</h2>

        <div class="settings-list">
          <div class="setting-row">
