        <%= link_to "Contact", contact_path %>
      </div>
      <div class="footer-copy">© <%= Date.today.year %> Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>

<%# ============================================================
    JavaScript inline — gestion des onglets et accordéon historique
    Simple et sans dépendance, correspond au comportement du mockup
============================================================= %>
<script>
  // Affiche l'onglet sélectionné et cache tous les autres
  function showTab(tab, btn) {
    // Liste de tous les ids d'onglets
    var tabs = ['fidelite', 'rdv', 'historique', 'messages', 'profil'];
    tabs.forEach(function(t) {
      var el = document.getElementById('tab-' + t);
      if (el) el.style.display = (t === tab) ? 'block' : 'none';
    });
    // Met à jour la classe "active" sur le bouton de nav
    document.querySelectorAll('.client-nav-item').forEach(function(b) {
      b.classList.remove('active');
    });
    btn.classList.add('active');
  }

  // Ouvre/ferme une carte d'historique au clic sur son header
  function toggleHistory(header) {
    var card = header.parentElement;
    card.classList.toggle('open');
  }

  // Bouton "Voir plus / Voir moins" sous une liste d'historique.
  // Toggle la classe `collapsed` sur la liste précédente (la liste juste au-dessus
  // du bouton dans le DOM) et met à jour le label + la rotation de la flèche.
  function toggleMore(btn) {
    var list = btn.previousElementSibling;
    list.classList.toggle('collapsed');
    // Après le toggle, on lit l'état pour décider quoi afficher.
    var isCollapsed = list.classList.contains('collapsed');
    // La classe `expanded` sur le bouton fait pivoter la flèche à 180° via CSS.
    btn.classList.toggle('expanded', !isCollapsed);
    // Met à jour le texte (data-count = nb d'items masqués au repos)
    var label = btn.querySelector('span');
    label.textContent = isCollapsed
      ? 'Voir les ' + btn.dataset.count + ' autres'
      : 'Voir moins';
  }
</script>
