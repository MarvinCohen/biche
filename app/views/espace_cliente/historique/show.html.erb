<% content_for :title, "Détail du soin" %>

<%#
  ============================================================
  VUE — Détail d'un soin passé avec la fiche technique complète
  Données : @booking et @soin_historique chargés par HistoriqueController#show
  ============================================================
%>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <%= link_to "← Historique", espace_cliente_historique_index_path, class: "logout-btn" %>
      </div>
    </nav>

    <%# ---- HEADER SOIN ---- %>
    <div class="page-header">
      <div class="ph-blob"></div>
      <p class="ph-tag"><%= I18n.l(@booking.date, format: "%-d %B %Y") %></p>
      <h1 class="ph-title"><%= @booking.prestation.nom %></h1>
      <%# Heure du soin et durée %>
      <p class="ph-intro">
        <%= @booking.heure.strftime('%Hh%M') if @booking.heure %>
        <% if @booking.heure_fin %>
          → <%= @booking.heure_fin.strftime('%Hh%M') %>
        <% end %>
        · <%= @booking.prestation.duree_minutes %> min
      </p>
    </div>

    <%# ---- FICHE TECHNIQUE ---- %>
    <div class="sec">
      <p class="s-tag">Fiche technique</p>

      <% if @soin_historique.present? %>
        <%# Paramètres techniques en grille 2×2 %>
        <% if @soin_historique.resume_technique.present? %>
          <div class="detail-grid" style="margin-bottom: 16px;">
            <%# Courbure des extensions %>
            <% if @soin_historique.courbure.present? %>
              <div class="detail-item">
                <div class="detail-label">Courbure</div>
                <div class="detail-value"><%= @soin_historique.courbure %></div>
              </div>
            <% end %>
            <%# Longueur des extensions %>
            <% if @soin_historique.longueur.present? %>
              <div class="detail-item">
                <div class="detail-label">Longueur</div>
                <div class="detail-value"><%= @soin_historique.longueur %></div>
              </div>
            <% end %>
            <%# Épaisseur du fil %>
            <% if @soin_historique.epaisseur.present? %>
              <div class="detail-item">
                <div class="detail-label">Épaisseur</div>
                <div class="detail-value"><%= @soin_historique.epaisseur %></div>
              </div>
            <% end %>
            <%# Technique utilisée (ex: Volume 2D, Cil à cil...) %>
            <% if @soin_historique.technique.present? %>
              <div class="detail-item">
                <div class="detail-label">Technique</div>
                <div class="detail-value"><%= @soin_historique.technique %></div>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Note personnalisée de Syam — colonne "note_syam" %>
        <% if @soin_historique.note_syam.present? %>
          <div class="detail-note">
            <div class="detail-note-label">Note de Syam</div>
            <div class="detail-note-text"><%= @soin_historique.note_syam %></div>
          </div>
        <% else %>
          <p style="font-size: 13px; color: var(--color-muted); font-style: italic;">
            Aucune note pour ce soin.
          </p>
        <% end %>

      <% else %>
        <%# Fiche non encore remplie par Syam %>
        <p style="font-size: 13px; color: var(--color-muted); font-style: italic;">
          La fiche technique n'a pas encore été remplie.
        </p>
      <% end %>
    </div>

    <%# ---- RÉCAPITULATIF TARIFAIRE ---- %>
    <div class="sec" style="padding-top: 0;">
      <p class="s-tag">Récapitulatif</p>
      <div class="recap-box">
        <div class="recap-row">
          <div class="recap-row-label">Prestation</div>
          <div class="recap-row-value"><%= @booking.prestation.nom %></div>
        </div>
        <div class="recap-row">
          <div class="recap-row-label">Date</div>
          <div class="recap-row-value"><%= I18n.l(@booking.date, format: "%-d %B %Y") %></div>
        </div>
        <div class="recap-row">
          <div class="recap-row-label">Lieu</div>
          <div class="recap-row-value">Calao Studio, Bordeaux</div>
        </div>
        <hr class="recap-divider">
        <div class="recap-row">
          <div class="recap-row-label recap-total-label">Total</div>
          <div class="recap-total">
            <%= number_to_currency(@booking.prestation.prix_euros, unit: "€", format: "%n%u", precision: 0) %>
          </div>
        </div>
      </div>

      <%# CTA : reprendre la même prestation %>
      <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 10px;">
        <%= link_to "Reprendre cette pose →",
                    new_booking_path(prestation_id: @booking.prestation_id),
                    class: "btn-primary" %>
        <%= link_to "Retour à l'historique",
                    espace_cliente_historique_index_path,
                    class: "btn-ghost" %>
      </div>
    </div>

    <%# ---- FOOTER ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-tag">Technicienne du regard · Bordeaux</div>
      <div class="footer-copy">© <%= Date.today.year %> Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>
