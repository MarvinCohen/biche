<%#
  ============================================================
  EMAIL 3 — Annulation de rendez-vous par Syam
  Variables disponibles : @booking, @user, @espace_url
  Le layout mailer.html.erb entoure ce contenu
  ============================================================
%>

<!-- Titre principal -->
<p style="margin:0 0 6px; font-size:13px; color:#8e8480; letter-spacing:1px; text-transform:uppercase;">
  Rendez-vous annulé
</p>
<h1 style="margin:0 0 24px; font-size:26px; color:#2e2926; font-family:'Georgia', serif; font-weight:400; line-height:1.3;">
  Votre rendez-vous a été annulé.
</h1>

<!-- Message d'explication -->
<p style="margin:0 0 24px; font-size:14px; color:#5a5450; line-height:1.8;">
  Bonjour <%= @user.first_name %>,
</p>
<p style="margin:0 0 24px; font-size:14px; color:#5a5450; line-height:1.8;">
  Nous vous informons que votre rendez-vous du
  <strong style="color:#2e2926;"><%= I18n.l(@booking.date, format: "%-d %B %Y") %></strong>
  <% if @booking.heure %>
    à <strong style="color:#2e2926;"><%= @booking.heure.strftime('%Hh%M') %></strong>
  <% end %>
  a été annulé.
</p>

<!-- Récapitulatif du RDV annulé -->
<table width="100%" cellpadding="0" cellspacing="0" style="background:#f6f4f1; border-radius:14px; margin-bottom:24px; overflow:hidden;">
  <tr>
    <td style="padding:18px 20px; border-bottom:1px solid #e8e2d8;">
      <!-- Prestation -->
      <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="font-size:11px; color:#8e8480; letter-spacing:0.5px;">Prestation</td>
          <td align="right" style="font-size:13px; color:#2e2926; font-weight:500;">
            <%= @booking.prestation.nom %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:18px 20px; border-bottom:1px solid #e8e2d8;">
      <!-- Date et heure -->
      <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="font-size:11px; color:#8e8480; letter-spacing:0.5px;">Date</td>
          <td align="right" style="font-size:13px; color:#2e2926; font-weight:500;">
            <%= I18n.l(@booking.date, format: "%-d %B %Y") %>
            <% if @booking.heure %>
              · <%= @booking.heure.strftime('%Hh%M') %>
            <% end %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:18px 20px;">
      <!-- Durée -->
      <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="font-size:11px; color:#8e8480; letter-spacing:0.5px;">Durée</td>
          <td align="right" style="font-size:13px; color:#2e2926; font-weight:500;">
            <%= @booking.prestation.duree_minutes %> minutes
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- Message d'invitation à reprogrammer -->
<p style="margin:0 0 24px; font-size:14px; color:#5a5450; line-height:1.8;">
  N'hésitez pas à prendre un nouveau rendez-vous directement depuis votre espace cliente.
</p>

<!-- Bouton CTA -->
<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
  <tr>
    <td align="center">
      <a href="<%= @espace_url %>"
         style="display:inline-block; padding:13px 32px; background:#2e2926; color:#fff;
                border-radius:30px; text-decoration:none; font-size:11px;
                letter-spacing:1.5px; text-transform:uppercase; font-weight:500;">
        Reprendre un rendez-vous
      </a>
    </td>
  </tr>
</table>

<!-- Signature -->
<p style="margin:0; font-size:12px; color:#8e8480; text-align:center; line-height:1.8;">
  À très bientôt,<br>
  <span style="color:#2e2926; font-style:italic; font-size:14px;">Syam · Biche.</span>
</p>
