<%#
  ============================================================
  Partial — champ mot de passe avec œil afficher/masquer.

  Locals attendus :
    - f            : le form builder Devise
    - field        : symbole du champ (:password ou :password_confirmation)
    - autocomplete : valeur HTML autocomplete ("new-password", "current-password")

  Le wrapper porte data-controller="password-toggle" — le controller
  Stimulus password_toggle_controller.js gere la bascule type=password
  / type=text et le swap des deux icones oeil.
  ============================================================
%>
<div class="auth-password-wrap" data-controller="password-toggle">
  <%# Input mot de passe — type="password" par défaut grâce à f.password_field.
      data-password-toggle-target="input" : ciblé par le JS pour swap le type. %>
  <%= f.password_field field,
                       autocomplete: autocomplete,
                       placeholder: "••••••••",
                       class: "auth-input",
                       data: { password_toggle_target: "input" } %>

  <%# Bouton œil — superposé à droite du champ. type="button" pour ne
      PAS soumettre le formulaire au clic. %>
  <button type="button"
          class="auth-password-toggle"
          data-action="click->password-toggle#toggle"
          aria-label="Afficher ou masquer le mot de passe">

    <%# Icône "œil ouvert" — visible quand le mot de passe est masqué (état par défaut) %>
    <svg data-password-toggle-target="iconShow"
         xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="1.8"
         stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>

    <%# Icône "œil barré" — visible quand le mot de passe est en clair %>
    <svg data-password-toggle-target="iconHide"
         xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="1.8"
         stroke-linecap="round" stroke-linejoin="round">
      <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-6.5 0-10-7-10-7a18.4 18.4 0 0 1 5.06-5.94"/>
      <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c6.5 0 10 7 10 7a18.4 18.4 0 0 1-2.16 3.19"/>
      <path d="M1 1l22 22"/>
      <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/>
    </svg>
  </button>
</div>
