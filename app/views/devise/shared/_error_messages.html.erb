<%#
  ============================================================
  PARTIAL — Messages d'erreur Devise (validation côté serveur)
  Utilisé dans toutes les vues Devise : login, inscription, mot de passe, etc.
  ============================================================
%>

<%# On n'affiche le bloc que si la ressource a des erreurs %>
<% if resource.errors.any? %>
  <div style="background:#fdecea; border-radius:12px; padding:14px 16px; margin-bottom:20px; border:1px solid #f5c6c6;" data-turbo-temporary>

    <%# Résumé : "1 erreur" ou "2 erreurs" %>
    <p style="font-size:13px; color:#c47a7a; font-weight:500; margin-bottom:8px;">
      <%= resource.errors.count == 1 ? "1 erreur" : "#{resource.errors.count} erreurs" %> à corriger :
    </p>

    <%# Liste des messages d'erreur traduits %>
    <ul style="font-size:12px; color:#c47a7a; padding-left:16px; line-height:1.8; margin:0;">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>

  </div>
<% end %>
