<%#
  ============================================================
  VUE — Connexion (Devise sessions#new)
  Champs : email + mot de passe
  ============================================================
%>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
    </nav>

    <%# ---- HEADER ---- %>
    <div class="page-header">
      <div class="ph-blob"></div>
      <p class="ph-tag">Espace cliente</p>
      <h1 class="ph-title">Bon retour<br>parmi nous</h1>
      <p class="ph-intro">Connectez-vous pour gérer vos rendez-vous et suivre votre programme fidélité.</p>
    </div>

    <%# ---- FORMULAIRE DE CONNEXION ---- %>
    <div class="sec">

      <%# form_for : génère le formulaire vers l'URL de connexion Devise %>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <%# --- Email --- %>
        <div class="auth-field">
          <%= f.label :email, "Adresse email", class: "auth-label" %>
          <%= f.email_field :email,
                            autofocus: true,
                            autocomplete: "email",
                            placeholder: "marie@example.com",
                            class: "auth-input" %>
        </div>

        <%# --- Mot de passe --- %>
        <div class="auth-field">
          <%= f.label :password, "Mot de passe", class: "auth-label" %>
          <%= render "devise/shared/password_field",
                     f: f, field: :password, autocomplete: "current-password" %>
        </div>

        <%# --- Se souvenir de moi (si le module rememberable est actif) --- %>
        <% if devise_mapping.rememberable? %>
          <div class="auth-remember">
            <%= f.check_box :remember_me, class: "auth-checkbox" %>
            <%= f.label :remember_me, "Se souvenir de moi", class: "auth-remember-label" %>
          </div>
        <% end %>

        <%# --- Bouton de connexion --- %>
        <%= f.submit "Se connecter", class: "btn-primary auth-submit" %>

      <% end %>

      <%# Liens secondaires : mot de passe oublié + créer un compte %>
      <div class="auth-links">
        <%= link_to "Mot de passe oublié ?", new_user_password_path, class: "auth-link" %>
        <p>Pas encore de compte ? <%= link_to "S'inscrire", new_user_registration_path, class: "auth-link" %></p>
      </div>

    </div>

    <%# ---- FOOTER MINIMALISTE ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-copy">© <%= Date.today.year %> Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>
