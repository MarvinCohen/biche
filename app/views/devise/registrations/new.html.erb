<%#
  ============================================================
  VUE — Inscription (Devise registrations#new)
  Champs : prénom, nom, email, mot de passe, confirmation
  ============================================================
%>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
    </nav>

    <%# ---- HEADER ---- %>
    <div class="page-header">
      <div class="ph-blob"></div>
      <p class="ph-tag">Compte</p>
      <h1 class="ph-title">Créer<br>mon compte</h1>
      <p class="ph-intro">Gérez vos réservations, suivez votre fidélité et accédez à votre espace cliente.</p>
    </div>

    <%# ---- FORMULAIRE D'INSCRIPTION ---- %>
    <div class="sec">

      <%# Affiche les erreurs de validation (champs manquants, email déjà pris, etc.) %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%# form_for : génère le formulaire vers l'URL d'inscription Devise %>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

        <%# --- Prénom et nom sur deux colonnes --- %>
        <div class="auth-row-2col">
          <div class="auth-field">
            <%= f.label :first_name, "Prénom", class: "auth-label" %>
            <%= f.text_field :first_name,
                             autofocus: true,
                             autocomplete: "given-name",
                             placeholder: "Marie",
                             class: "auth-input" %>
          </div>
          <div class="auth-field">
            <%= f.label :last_name, "Nom", class: "auth-label" %>
            <%= f.text_field :last_name,
                             autocomplete: "family-name",
                             placeholder: "Lefèvre",
                             class: "auth-input" %>
          </div>
        </div>

        <%# --- Email --- %>
        <div class="auth-field">
          <%= f.label :email, "Adresse email", class: "auth-label" %>
          <%= f.email_field :email,
                            autocomplete: "email",
                            placeholder: "marie@example.com",
                            class: "auth-input" %>
        </div>

        <%# --- Téléphone (optionnel) --- %>
        <div class="auth-field">
          <%= f.label :phone, "Téléphone (optionnel)", class: "auth-label" %>
          <%= f.telephone_field :phone,
                                autocomplete: "tel",
                                placeholder: "06 12 34 56 78",
                                class: "auth-input" %>
        </div>

        <%# --- Mot de passe --- %>
        <div class="auth-field">
          <%= f.label :password, "Mot de passe", class: "auth-label" %>
          <% if @minimum_password_length %>
            <span class="auth-hint"><%= @minimum_password_length %> caractères minimum</span>
          <% end %>
          <%= render "devise/shared/password_field",
                     f: f, field: :password, autocomplete: "new-password" %>
        </div>

        <%# --- Confirmation du mot de passe --- %>
        <div class="auth-field">
          <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "auth-label" %>
          <%= render "devise/shared/password_field",
                     f: f, field: :password_confirmation, autocomplete: "new-password" %>
        </div>

        <%# --- Bouton de soumission --- %>
        <%= f.submit "Créer mon compte", class: "btn-primary auth-submit" %>

      <% end %>

      <%# Lien vers la connexion si compte déjà existant %>
      <div class="auth-links">
        <p>Déjà un compte ? <%= link_to "Se connecter", new_user_session_path, class: "auth-link" %></p>
      </div>

    </div>

    <%# ---- FOOTER MINIMALISTE ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-copy">© <%= Date.today.year %> Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>
