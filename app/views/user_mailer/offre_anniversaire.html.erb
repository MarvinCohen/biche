<%#
  EMAIL — Offre anniversaire
  Envoyé automatiquement le jour de l'anniversaire de la cliente
  Variables : @user, @espace_url, @booking_url
%>

<!-- Tag -->
<p style="font-size:11px; color:#b8a898; letter-spacing:3px; text-transform:uppercase; margin:0 0 8px;">
  Offre anniversaire
</p>

<!-- Titre -->
<h1 style="font-size:26px; color:#2e2926; margin:0 0 12px; font-weight:400; line-height:1.2;">
  Joyeux anniversaire<br><%= @user.first_name %> !
</h1>

<p style="font-size:14px; color:#6e6560; line-height:1.7; margin:0 0 24px;">
  Toute l'équipe Biche. vous souhaite un magnifique anniversaire. Pour fêter ça, Syam vous offre un cadeau spécial.
</p>

<!-- Offre mise en valeur -->
<table width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(135deg,#2e2926,#4e4a46); border-radius:18px; padding:28px; margin-bottom:24px; text-align:center;">
  <tr>
    <td>
      <!-- Étoile décorative -->
      <div style="font-size:32px; margin-bottom:12px; opacity:0.8;">✦</div>
      <div style="font-size:11px; color:#b8a898; letter-spacing:3px; text-transform:uppercase; margin-bottom:8px;">
        Votre cadeau
      </div>
      <div style="font-size:32px; color:#fff; font-weight:300; margin-bottom:6px;">
        -10%
      </div>
      <div style="font-size:14px; color:rgba(255,255,255,0.7); margin-bottom:16px;">
        sur votre prochain soin
      </div>
      <div style="font-size:10px; color:rgba(255,255,255,0.4); letter-spacing:1px;">
        Valable 30 jours · Non cumulable
      </div>
    </td>
  </tr>
</table>

<p style="font-size:13px; color:#6e6560; line-height:1.7; margin:0 0 24px; text-align:center;">
  Mentionnez simplement votre anniversaire lors de votre prochaine réservation et Syam appliquera la réduction directement.
</p>

<!-- Bouton CTA -->
<div style="text-align:center; margin-bottom:24px;">
  <%= link_to "Prendre rendez-vous", @booking_url,
              style: "display:inline-block; background:#2e2926; color:#fff; text-decoration:none; padding:13px 28px; border-radius:40px; font-size:11px; letter-spacing:1.5px; text-transform:uppercase; font-weight:500;" %>
</div>

<!-- Message chaleureux -->
<div style="border-top:1px solid #e8e2d8; padding-top:20px; text-align:center;">
  <p style="font-size:13px; color:#8e8480; line-height:1.7; margin:0; font-style:italic;">
    « Prenez soin de vous, vous le méritez. »<br>
    <span style="font-size:12px; color:#b8a898;">— Syam</span>
  </p>
</div>
