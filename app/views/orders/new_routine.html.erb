<%# ============================================================
    Page de récap avant achat d'un produit routine (nettoyant cils, sérum, etc.).

    Reprend exactement le même style que `orders/new_pack.html.erb`
    pour conserver la cohérence visuelle dans le tunnel d'achat.

    Pour la démo, le bouton "Confirmer l'achat" envoie un POST direct vers
    /orders/create_routine qui crée l'Order avec statut `paye` (sans Stripe).
============================================================ %>
<% content_for :title, "Achat — #{@produit.nom}" %>

<% content_for :head do %>
<style>
  /* Container principal — mêmes paddings que les autres pages "tunnel" */
  .pack-recap-wrap { padding: 32px 20px 40px; }

  /* Bouton "retour boutique" en haut — discret */
  .pack-recap-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--color-muted, #8e8480);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 20px;
  }

  /* En-tête : tag + titre + sous-titre */
  .pack-recap-tag {
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--color-muted, #988e88);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .pack-recap-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    color: var(--color-dark, #2e2926);
    line-height: 1.2;
    margin-bottom: 8px;
    font-weight: 400;
  }
  .pack-recap-sub {
    font-size: 13px;
    color: var(--color-muted, #6e6560);
    line-height: 1.6;
    margin-bottom: 26px;
  }

  /* Aperçu photo du produit (si dispo) — coins arrondis, ratio carré */
  .routine-recap-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 18px;
    background: var(--color-cream, #f6f4f1);
  }
  .routine-recap-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Carte récap — détails de l'achat */
  .pack-recap-card {
    background: #fff;
    border: 1px solid var(--color-border, #e2dbd2);
    border-radius: 20px;
    padding: 22px 20px;
    margin-bottom: 22px;
  }
  .pack-recap-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border, #f0ede8);
    font-size: 13px;
  }
  /* Dernière ligne — pas de bordure inférieure */
  .pack-recap-row:last-of-type { border-bottom: none; }

  .pack-recap-label {
    color: var(--color-muted, #8e8480);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 10px;
  }
  .pack-recap-value {
    color: var(--color-dark, #2e2926);
    font-weight: 500;
    text-align: right;
    /* Permet à la description longue de wrapper proprement */
    max-width: 60%;
  }

  /* Ligne total — espacée du bloc du dessus, sans séparateur (trop visuel). */
  .pack-recap-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 18px;
    padding-top: 8px;
  }
  .pack-recap-total-label {
    font-size: 12px;
    color: var(--color-dark, #2e2926);
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }
  .pack-recap-total-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    color: var(--color-dark, #2e2926);
  }

  /* Encart info sur le mode de paiement (démo : pas de Stripe) */
  .pack-recap-info {
    background: var(--color-cream, #f6f4f1);
    border-radius: 14px;
    padding: 14px 16px;
    font-size: 12px;
    color: var(--color-muted, #6e6560);
    line-height: 1.6;
    margin-bottom: 22px;
  }

  /* Bouton principal de confirmation */
  .pack-recap-btn {
    display: block;
    width: 100%;
    background: var(--color-dark, #2e2926);
    color: #fff;
    border: none;
    border-radius: 30px;
    padding: 15px 24px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-family: inherit;
    cursor: pointer;
  }
</style>
<% end %>

<div class="wrap">
  <div class="phone">
    <div class="pack-recap-wrap">

      <%# Lien retour boutique — toujours dispo pour annuler %>
      <%= link_to shop_path, class: "pack-recap-back" do %>
        ← Retour boutique
      <% end %>

      <%# En-tête %>
      <div class="pack-recap-tag">Récapitulatif</div>
      <div class="pack-recap-title"><%= @produit.nom %></div>
      <div class="pack-recap-sub">
        Votre achat sera ajouté à votre historique boutique immédiatement.
      </div>

      <%# Aperçu photo si disponible — pour reconnaître le produit en un coup d'œil %>
      <% if @produit.photo.attached? %>
        <div class="routine-recap-photo">
          <%= image_tag @produit.photo, alt: @produit.nom %>
        </div>
      <% end %>

      <%# Carte récap : produit + description + prix %>
      <div class="pack-recap-card">
        <div class="pack-recap-row">
          <div class="pack-recap-label">Produit</div>
          <div class="pack-recap-value"><%= @produit.nom %></div>
        </div>

        <%# Description seulement si renseignée pour éviter une ligne vide %>
        <% if @produit.description.present? %>
          <div class="pack-recap-row">
            <div class="pack-recap-label">Description</div>
            <div class="pack-recap-value"><%= @produit.description %></div>
          </div>
        <% end %>

        <%# Ligne total mise en avant %>
        <div class="pack-recap-total">
          <div class="pack-recap-total-label">Total</div>
          <div class="pack-recap-total-value"><%= @produit.prix_euros.to_i %>€</div>
        </div>
      </div>

      <%# Encart info — pendant la démo, on précise qu'il n'y a pas encore de paiement réel %>
      <div class="pack-recap-info">
        ℹ️ Mode démo — l'achat est confirmé immédiatement, sans paiement bancaire.
        Le paiement Stripe sera activé en production.
      </div>

      <%# Formulaire de soumission — POST vers create_routine avec le product_id %>
      <%# CSRF inclus automatiquement par Rails via button_to %>
      <%= button_to "Confirmer l'achat",
                    create_routine_orders_path(product_id: @produit.id),
                    method: :post,
                    class: "pack-recap-btn" %>

    </div>
  </div>
</div>
