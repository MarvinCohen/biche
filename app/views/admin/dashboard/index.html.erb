<% content_for :title, "Admin — Planning" %>

<%#
  ============================================================
  VUE — Dashboard admin Syam
  Planning du jour + RDV en attente + stats du mois
  Données : @rdvs_du_jour, @rdvs_en_attente, @date, @nb_*
  ============================================================
%>

<div class="admin-wrap">
  <div class="admin-phone">

    <%# ---- NAVIGATION ADMIN ---- %>
    <nav class="admin-nav">
      <%= link_to admin_root_path, class: "admin-nav-logo" do %>
        Biche.
        <span>Admin</span>
      <% end %>
      <%= link_to "Déconnexion",
                  destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "admin-logout" %>
    </nav>

    <%# ---- HEADER + STATS ---- %>
    <div class="admin-header">
      <div class="admin-header-title">Bonjour, Syam !</div>
      <div class="admin-header-sub">
        <%= I18n.l(Date.today, format: "%A %-d %B %Y").capitalize %>
      </div>
    </div>

    <%#
      Stats enrichies — grille 2×2
      Ligne 1 : RDV du jour + CA du jour
      Ligne 2 : RDV du mois + CA du mois
    %>
    <div class="admin-stats">
      <%# Nombre de RDV pour la date affichée (hors annulés) %>
      <div class="admin-stat">
        <span class="admin-stat-num"><%= @nb_rdvs_aujourd_hui %></span>
        <span class="admin-stat-label">RDV du jour</span>
      </div>

      <%# CA du jour : somme des prestations confirmées / terminées, en euros %>
      <div class="admin-stat">
        <span class="admin-stat-num"><%= "#{(@ca_jour / 100.0).round}€" %></span>
        <span class="admin-stat-label">CA du jour</span>
      </div>

      <%# Nombre de RDV confirmés ou terminés ce mois %>
      <div class="admin-stat admin-stat--border-top">
        <span class="admin-stat-num"><%= @nb_rdvs_mois %></span>
        <span class="admin-stat-label">RDV du mois</span>
      </div>

      <%# CA du mois : somme des prestations confirmées / terminées ce mois, en euros %>
      <div class="admin-stat admin-stat--border-top">
        <span class="admin-stat-num"><%= "#{(@ca_mois / 100.0).round}€" %></span>
        <span class="admin-stat-label">CA du mois</span>
      </div>
    </div>

    <%# ---- NAVIGATION PAR DATE ---- %>
    <%# Flèches pour naviguer jour par jour %>
    <div class="admin-date-nav">
      <%# Jour précédent %>
      <%= link_to admin_root_path(date: (@date - 1.day).to_s), class: "admin-date-nav-btn" do %>
        ←
      <% end %>

      <%# Date affichée %>
      <div class="admin-date-label">
        <% if @date == Date.today %>
          Aujourd'hui
        <% elsif @date == Date.today + 1 %>
          Demain
        <% else %>
          <%= I18n.l(@date, format: "%-d %B") %>
        <% end %>
      </div>

      <%# Jour suivant %>
      <%= link_to admin_root_path(date: (@date + 1.day).to_s), class: "admin-date-nav-btn" do %>
        →
      <% end %>
    </div>

    <%# ---- PLANNING DU JOUR ---- %>
    <div class="admin-sec">
      <div class="admin-sec-title">
        Planning — <%= I18n.l(@date, format: "%-d %B %Y") %>
      </div>

      <% if @rdvs_du_jour.any? %>
        <% @rdvs_du_jour.each do |booking| %>
          <%# Chaque carte RDV est cliquable → détail %>
          <%= link_to admin_booking_path(booking), class: "admin-rdv-card" do %>
            <%# Bloc heure %>
            <div class="admin-rdv-heure">
              <%= booking.heure.strftime('%H') if booking.heure %><br>
              <span style="font-size:10px; opacity:0.7;"><%= booking.heure.strftime('%M') if booking.heure %></span>
            </div>

            <%# Infos %>
            <div class="admin-rdv-info">
              <div class="admin-rdv-cliente"><%= booking.user.full_name %></div>
              <div class="admin-rdv-prestation"><%= booking.prestation.nom %> · <%= booking.prestation.duree_minutes %> min</div>
              <%# Badge de statut %>
              <% badge_class = case booking.statut
                               when 'en_attente' then 'admin-badge-attente'
                               when 'confirme'   then 'admin-badge-confirme'
                               when 'termine'    then 'admin-badge-termine'
                               else 'admin-badge-annule'
                               end %>
              <span class="admin-badge <%= badge_class %>">
                <%= { 'en_attente' => 'En attente', 'confirme' => 'Confirmé', 'termine' => 'Terminé', 'annule' => 'Annulé' }[booking.statut] %>
              </span>
            </div>

            <%# Flèche %>
            <div style="color: #c8c2bc; font-size: 14px;">›</div>
          <% end %>
        <% end %>

      <% else %>
        <div class="admin-empty">
          <div class="admin-empty-text">Aucun rendez-vous ce jour.</div>
        </div>
      <% end %>
    </div>

    <%# ---- RDV EN ATTENTE DE CONFIRMATION ---- %>
    <% if @rdvs_en_attente.any? %>
      <div class="admin-sec">
        <div class="admin-sec-title">
          À confirmer (<%= @rdvs_en_attente.count %>)
        </div>

        <% @rdvs_en_attente.each do |booking| %>
          <%= link_to admin_booking_path(booking), class: "admin-rdv-card" do %>
            <div class="admin-rdv-heure" style="background:#c47a2a;">
              <%= booking.date.day %><br>
              <span style="font-size:9px; opacity:0.8;"><%= I18n.l(booking.date, format: "%b") %></span>
            </div>
            <div class="admin-rdv-info">
              <div class="admin-rdv-cliente"><%= booking.user.full_name %></div>
              <div class="admin-rdv-prestation">
                <%= booking.prestation.nom %> · <%= booking.heure.strftime('%Hh%M') if booking.heure %>
              </div>
              <span class="admin-badge admin-badge-attente">En attente</span>
            </div>
            <div style="color: #c8c2bc; font-size: 14px;">›</div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# ---- NAVIGATION EN GRILLE D'ICÔNES ---- %>
    <%# Chaque tuile : emoji large + label court, 2 colonnes %>
    <div class="admin-sec">
      <div class="admin-sec-title">Navigation</div>
      <div class="admin-nav-grid">

        <%# Tuile principale — fond sombre, mise en avant %>
        <%= link_to new_admin_booking_path(date: @date.to_s), class: "admin-nav-tile admin-nav-tile--primary" do %>
          <span class="admin-nav-tile-icon">📅</span>
          <span class="admin-nav-tile-label">Nouveau RDV</span>
        <% end %>

        <%= link_to admin_agenda_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">🗓</span>
          <span class="admin-nav-tile-label">Agenda</span>
        <% end %>

        <%= link_to admin_bookings_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">📋</span>
          <span class="admin-nav-tile-label">Réservations</span>
        <% end %>

        <%= link_to admin_users_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">👥</span>
          <span class="admin-nav-tile-label">Clientes</span>
        <% end %>

        <%= link_to admin_prestations_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">💅</span>
          <span class="admin-nav-tile-label">Prestations</span>
        <% end %>

        <%= link_to admin_products_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">🛍️</span>
          <span class="admin-nav-tile-label">Boutique</span>
        <% end %>

        <%= link_to admin_indisponibilites_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">🚫</span>
          <span class="admin-nav-tile-label">Bloqués</span>
        <% end %>

        <%= link_to admin_cartes_cadeaux_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">🎁</span>
          <span class="admin-nav-tile-label">Cadeaux</span>
        <% end %>

        <%= link_to admin_galerie_photos_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">🖼️</span>
          <span class="admin-nav-tile-label">Galerie</span>
        <% end %>

        <%= link_to new_admin_message_path, class: "admin-nav-tile" do %>
          <span class="admin-nav-tile-icon">💬</span>
          <span class="admin-nav-tile-label">Message</span>
        <% end %>

      </div>
    </div>

  </div>
</div>
