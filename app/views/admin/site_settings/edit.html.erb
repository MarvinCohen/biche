<% content_for :title, "Admin — Réglages du site" %>

<%#
  ============================================================
  VUE — Formulaire d'édition des réglages globaux du site
  Pour l'instant : URL de la dernière vidéo TikTok à afficher
  sur la home et la galerie.
  ============================================================
%>

<div class="admin-wrap">
  <div class="admin-phone">

    <%# ---- NAVIGATION ADMIN ---- %>
    <nav class="admin-nav">
      <%= link_to admin_root_path, class: "admin-nav-logo" do %>
        Biche. <span>Admin</span>
      <% end %>
      <%= link_to "← Retour", admin_root_path, class: "admin-logout" %>
    </nav>

    <%# ---- HEADER ---- %>
    <div class="admin-header">
      <div class="admin-header-title">Réglages du site</div>
      <div class="admin-header-sub">Modifications instantanées sur le site public</div>
    </div>

    <%# ---- FORMULAIRE ---- %>
    <div class="admin-sec">
      <%# `form_with url:` car le controller ne suit pas le pattern CRUD
          classique (clé/valeur, pas un enregistrement par ressource).
          `multipart: true` est OBLIGATOIRE quand on a un file_field —
          sinon le navigateur n'envoie pas le fichier (juste son nom). %>
      <%= form_with url: admin_site_settings_path, method: :patch, local: true, multipart: true do %>

        <%# ---- VIDÉO (player natif sur le site) ---- %>
        <h3 style="font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--color-dark); margin-bottom:12px;">
          Vidéo mise en avant (home + galerie)
        </h3>

        <%# Si une vidéo est déjà en place, on l'affiche pour que Syam
            voie quel fichier est actuellement en ligne, avec son nom. %>
        <% if @video_setting.video_file.attached? %>
          <div style="background:var(--color-cream); padding:12px; border-radius:10px; margin-bottom:12px; font-size:12px; color:var(--color-dark);">
            Vidéo actuelle :
            <strong><%= @video_setting.video_file.filename %></strong>
            (<%= number_to_human_size(@video_setting.video_file.byte_size) %>)

            <%# Case à cocher pour supprimer la vidéo actuelle.
                Côté controller, on lit `remove_video == "1"` et on purge l'attachement. %>
            <div style="margin-top:8px;">
              <%= check_box_tag "site_settings[remove_video]", "1", false, id: "remove_video" %>
              <label for="remove_video" style="font-size:11px; color:var(--color-muted);">
                Supprimer la vidéo actuelle
              </label>
            </div>
          </div>
        <% end %>

        <%# Champ d'upload du fichier MP4. accept=video/mp4 → le navigateur
            filtre la sélection (le contrôle serveur reste à faire si on
            veut être strict, ici on fait confiance à Syam côté admin). %>
        <div class="form-group" style="margin-bottom:16px;">
          <label for="video_file"
                 style="display:block; font-size:12px; color:var(--color-muted); margin-bottom:6px;">
            <% if @video_setting.video_file.attached? %>
              Remplacer la vidéo (MP4)
            <% else %>
              Uploader une vidéo (MP4)
            <% end %>
          </label>
          <%= file_field_tag "site_settings[video_file]",
                             accept: "video/mp4",
                             id: "video_file",
                             class: "admin-input" %>
          <div style="font-size:10px; color:var(--color-muted); margin-top:4px;">
            Télécharge la vidéo depuis TikTok (via SnapTik ou TTDownloader)
            puis sélectionne le fichier MP4 ici. Format recommandé : portrait, &lt; 30 Mo.
          </div>
        </div>

        <%# Légende affichée sous la vidéo (ex: "Pose volume 5D"). Optionnel. %>
        <div class="form-group" style="margin-bottom:24px;">
          <label for="video_caption"
                 style="display:block; font-size:12px; color:var(--color-muted); margin-bottom:6px;">
            Légende sous la vidéo (optionnel)
          </label>
          <%= text_field_tag "site_settings[video_caption]",
                             @video_setting.value,
                             id: "video_caption",
                             placeholder: "Ex: Pose volume 5D — Effet wispy",
                             class: "admin-input" %>
        </div>

        <%= submit_tag "Enregistrer", class: "btn-admin-terminer" %>
        <%= link_to "Annuler", admin_root_path, class: "btn-admin-fiche", style: "margin-top:8px;" %>

      <% end %>
    </div>

  </div>
</div>
