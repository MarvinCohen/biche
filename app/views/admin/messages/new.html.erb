<% content_for :title, "Admin — Nouveau message" %>

<%#
  ============================================================
  VUE — Formulaire d'envoi de message à une ou toutes les clientes
  Données : @message, @clientes
  params[:user_id] pré-sélectionne une cliente si passé en URL
  ============================================================
%>

<div class="admin-wrap">
  <div class="admin-phone">

    <nav class="admin-nav">
      <%= link_to admin_root_path, class: "admin-nav-logo" do %>
        Biche. <span>Admin</span>
      <% end %>
      <%= link_to "← Dashboard", admin_root_path, class: "admin-logout" %>
    </nav>

    <div class="admin-header">
      <div class="admin-header-title">Nouveau message</div>
      <div class="admin-header-sub">Envoyer une notification à vos clientes</div>
    </div>

    <div class="admin-sec">

      <%= form_with model: [:admin, @message], url: admin_messages_path, local: true do |f| %>

        <%# ---- DESTINATAIRE ---- %>
        <div class="admin-field">
          <%= f.label :user_id, "Destinataire", class: "admin-label" %>
          <%# select : option "Toutes" + liste des clientes %>
          <%= f.select :user_id,
                       options_for_select(
                         [["Toutes les clientes", "all"]] +
                         @clientes.map { |u| [u.full_name, u.id] },
                         params[:user_id] || "all"  # pré-sélection si passé en URL
                       ),
                       {},
                       class: "admin-select" %>
        </div>

        <%# ---- TYPE DE MESSAGE ---- %>
        <div class="admin-field">
          <%= f.label :type_message, "Type", class: "admin-label" %>
          <%= f.select :type_message,
                       options_for_select([
                         ["Actualité / Info",    "news"],
                         ["Promotion",           "promo"],
                         ["Offre anniversaire",  "anniversaire"],
                         ["Rappel rendez-vous",  "rappel_rdv"]
                       ]),
                       {},
                       class: "admin-select" %>
        </div>

        <%# ---- TITRE ---- %>
        <div class="admin-field">
          <%= f.label :titre, "Titre", class: "admin-label" %>
          <%= f.text_field :titre,
                           class: "admin-input",
                           placeholder: "Ex : Offre printemps — 10% sur le rehaussement" %>
        </div>

        <%# ---- CONTENU ---- %>
        <div class="admin-field">
          <%= f.label :contenu, "Message", class: "admin-label" %>
          <%= f.text_area :contenu,
                          class: "admin-textarea",
                          rows: 5,
                          placeholder: "Contenu du message affiché dans l'espace cliente..." %>
        </div>

        <%= f.submit "Envoyer", class: "btn-admin-terminer" %>
        <%= link_to "Annuler", admin_root_path, class: "btn-admin-fiche", style: "margin-top:8px;" %>

      <% end %>

    </div>

  </div>
</div>
