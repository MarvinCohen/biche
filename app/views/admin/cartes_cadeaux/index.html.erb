<% content_for :title, "Admin — Cartes cadeaux" %>

<div class="admin-wrap">
  <div class="admin-phone">

    <nav class="admin-nav">
      <%= link_to admin_root_path, class: "admin-nav-logo" do %>
        Biche. <span>Admin</span>
      <% end %>
      <%= link_to "← Accueil", admin_root_path, class: "admin-logout" %>
    </nav>

    <div class="admin-header">
      <div class="admin-header-title">Cartes cadeaux</div>
      <div class="admin-header-sub"><%= @cartes_actives.count %> active<%= 's' if @cartes_actives.count > 1 %></div>
    </div>

    <%# Bouton scanner %>
    <div style="padding:0 16px 16px;">
      <%= link_to "⬛ Scanner / Rechercher une carte", scanner_admin_cartes_cadeaux_path, class: "btn-admin-confirmer" %>
    </div>

    <%# Cartes actives %>
    <div class="admin-sec">
      <div class="admin-sec-title">Actives (<%= @cartes_actives.count %>)</div>

      <% if @cartes_actives.any? %>
        <% @cartes_actives.each do |carte| %>
          <%= link_to admin_carte_cadeau_path(carte), class: "admin-rdv-card" do %>
            <%# Solde visuel %>
            <div class="admin-rdv-heure" style="background:#3a3330;">
              <%= carte.solde_euros.to_i %>€
              <span style="font-size:9px; opacity:0.6; display:block;">/ <%= carte.montant_initial_euros.to_i %>€</span>
            </div>
            <div class="admin-rdv-info">
              <div class="admin-rdv-cliente" style="font-family:'Courier New',monospace; font-size:12px;"><%= carte.code %></div>
              <div class="admin-rdv-prestation">
                <% if carte.order.destinataire_nom.present? %>Pour <%= carte.order.destinataire_nom %> · <% end %>
                <%= I18n.l(carte.created_at.to_date, format: "%-d %B %Y") %>
              </div>
              <%# Barre de solde restant %>
              <div style="background:#e8e2d8; border-radius:3px; height:3px; margin-top:6px; width:100%;">
                <div style="background:#b8a898; border-radius:3px; height:3px; width:<%= carte.pourcentage_restant %>%;"></div>
              </div>
            </div>
            <div style="color:#c8c2bc; font-size:14px;">›</div>
          <% end %>
        <% end %>
      <% else %>
        <div class="admin-empty">
          <div class="admin-empty-text">Aucune carte active.</div>
        </div>
      <% end %>
    </div>

    <%# Cartes épuisées %>
    <% if @cartes_epuisees.any? %>
      <div class="admin-sec">
        <div class="admin-sec-title" style="color:var(--color-muted);">Épuisées (<%= @cartes_epuisees.count %>)</div>
        <% @cartes_epuisees.each do |carte| %>
          <%= link_to admin_carte_cadeau_path(carte), class: "admin-rdv-card", style: "opacity:0.5;" do %>
            <div class="admin-rdv-heure" style="background:#a09890;">0€</div>
            <div class="admin-rdv-info">
              <div class="admin-rdv-cliente" style="font-family:'Courier New',monospace; font-size:12px;"><%= carte.code %></div>
              <div class="admin-rdv-prestation">
                <%= carte.montant_initial_euros.to_i %>€ · utilisée le <%= I18n.l(carte.updated_at.to_date, format: "%-d %B %Y") %>
              </div>
            </div>
            <div style="color:#c8c2bc; font-size:14px;">›</div>
          <% end %>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
