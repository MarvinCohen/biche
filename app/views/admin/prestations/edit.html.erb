<% content_for :title, "Admin — Modifier #{@prestation.nom}" %>

<div class="admin-wrap">
  <div class="admin-phone">

    <nav class="admin-nav">
      <%= link_to admin_root_path, class: "admin-nav-logo" do %>
        Biche. <span>Admin</span>
      <% end %>
      <%= link_to "← Prestations", admin_prestations_path, class: "admin-logout" %>
    </nav>

    <div class="admin-header">
      <div class="admin-header-title"><%= @prestation.nom %></div>
      <div class="admin-header-sub">
        <%# Mapping catégorie interne → libellé affiché en admin %>
        <%= { 'extensions' => 'Extensions', 'retouche' => 'Remplissages',
              'rehaussement' => 'Rehaussement', 'depose' => 'Dépose' }[@prestation.categorie] %>
      </div>
    </div>

    <div class="admin-sec">
      <%= form_with model: [:admin, @prestation], local: true, multipart: true do |f| %>
        <%= render "form", f: f %>

        <%= f.submit "Enregistrer", class: "btn-admin-terminer" %>
        <%= link_to "Annuler", admin_prestations_path, class: "btn-admin-fiche", style: "margin-top:8px;" %>
      <% end %>
    </div>

    <%# ---- ZONE DANGER : suppression ---- %>
    <div class="admin-sec">
      <div class="admin-sec-title" style="color:#c47a7a;">Zone danger</div>
      <%= button_to "Supprimer cette prestation",
                    admin_prestation_path(@prestation),
                    method: :delete,
                    data: { turbo_confirm: "Supprimer définitivement \"#{@prestation.nom}\" ? Cette action est irréversible." },
                    class: "btn-admin-annuler" %>
      <div style="font-size:10px; color:var(--color-muted); margin-top:6px; text-align:center; letter-spacing:0.3px;">
        Impossible si des réservations existent pour cette prestation.
      </div>
    </div>

  </div>
</div>
