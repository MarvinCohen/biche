<% content_for :title, "Admin — Boutique" %>

<div class="admin-wrap">
  <div class="admin-phone">

    <nav class="admin-nav">
      <%= link_to admin_root_path, class: "admin-nav-logo" do %>
        Biche. <span>Admin</span>
      <% end %>
      <%= link_to "← Dashboard", admin_root_path, class: "admin-logout" %>
    </nav>

    <div class="admin-header">
      <div class="admin-header-title">Boutique</div>
      <div class="admin-header-sub">Routines, packs et cartes cadeaux</div>
    </div>

    <div class="admin-sec">
      <%= link_to "＋ Nouveau produit", new_admin_product_path, class: "btn-admin-confirmer" %>
    </div>

    <%# ---- LISTE PAR TYPE ---- %>
    <% labels = { 'routine' => 'Routine', 'pack' => 'Packs', 'carte_cadeau' => 'Cartes cadeaux' } %>

    <% if @products_par_type.any? %>
      <% @products_par_type.each do |type, products| %>
        <div class="admin-sec">
          <div class="admin-sec-title"><%= labels[type] || type.capitalize %></div>

          <% products.each do |product| %>
            <%= link_to edit_admin_product_path(product), class: "admin-rdv-card" do %>

              <%# Miniature %>
              <div class="admin-presta-thumb">
                <% if product.photo.attached? %>
                  <%= image_tag product.photo, style: "width:100%; height:100%; object-fit:cover;" %>
                <% else %>
                  <span style="font-size:18px;">🛍</span>
                <% end %>
              </div>

              <div class="admin-rdv-info">
                <div class="admin-rdv-cliente" style="<%= 'opacity:0.4;' unless product.actif %>">
                  <%= product.nom %>
                  <% unless product.actif %>
                    <span class="admin-badge admin-badge-annule" style="margin-left:6px;">Masqué</span>
                  <% end %>
                </div>
                <div class="admin-rdv-prestation">
                  <%# Pour les packs : on affiche aussi la pose + nb de remplissages
                      pour que Syam s'y retrouve rapidement dans une liste de 18 packs. %>
                  <% if product.pack? && product.prestation %>
                    <%= product.prestation.nom %> · <%= product.nb_remplissages %> remplissages ·
                  <% end %>
                  <%= product.prix_euros.to_i %>€
                </div>
              </div>

              <div style="color:#c8c2bc; font-size:14px;">›</div>
            <% end %>
          <% end %>
        </div>
      <% end %>

    <% else %>
      <div class="admin-sec">
        <div class="admin-empty">
          <div class="admin-empty-text">
            Aucun produit.<br>
            <span style="font-size:11px; opacity:0.7;">Ajoutez des produits pour les afficher dans la boutique.</span>
          </div>
        </div>
      </div>
    <% end %>

  </div>
</div>
