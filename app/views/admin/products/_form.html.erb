<%#
  ============================================================
  PARTIAL — Formulaire produit (partagé new + edit)
  ============================================================
%>

<% if @product.errors.any? %>
  <div class="admin-errors">
    <% @product.errors.full_messages.each do |msg| %>
      <div class="admin-error-item">⚠ <%= msg %></div>
    <% end %>
  </div>
<% end %>

<%# ---- NOM ---- %>
<div class="admin-field">
  <%= f.label :nom, "Nom du produit", class: "admin-label" %>
  <%= f.text_field :nom, class: "admin-input", placeholder: "Ex: Sérum cils fortifiant" %>
</div>

<%# ---- TYPE ---- %>
<%# data-product-type-select sert d'identifiant pour le JS qui affiche/cache
    les champs spécifiques aux packs (prestation + nb_remplissages) en fonction
    de la valeur choisie ici. %>
<div class="admin-field">
  <%= f.label :type_produit, "Type", class: "admin-label" %>
  <%= f.select :type_produit,
               options_for_select(
                 [
                   ["Routine (produit d'entretien)", "routine"],
                   ["Pack de remplissages",          "pack"],
                   ["Carte cadeau",                  "carte_cadeau"]
                 ],
                 @product.type_produit
               ),
               { include_blank: "Choisir un type" },
               class: "admin-select",
               data: { product_type_select: true } %>
</div>

<%# ---- CHAMPS SPÉCIFIQUES PACKS (visibles uniquement si type = pack) ---- %>
<%# Le bloc est masqué par défaut côté serveur si type_produit != 'pack'.
    Le petit JS en bas du formulaire toggle l'affichage quand la valeur change. %>
<div data-product-pack-fields
     style="<%= 'display:none;' unless @product.pack? %>">

  <%# Pose associée — uniquement les prestations de catégorie "extensions" %>
  <div class="admin-field">
    <%= f.label :prestation_id, "Type de pose", class: "admin-label" %>
    <%= f.collection_select :prestation_id,
                            @poses_disponibles, :id, :nom,
                            { include_blank: "Choisir une pose" },
                            class: "admin-select" %>
  </div>

  <%# Nombre de remplissages inclus — uniquement 3 / 6 / 9 (constante du modèle) %>
  <div class="admin-field">
    <%= f.label :nb_remplissages, "Nombre de remplissages", class: "admin-label" %>
    <%= f.select :nb_remplissages,
                 options_for_select(
                   Product::NB_REMPLISSAGES_AUTORISES.map { |n| [n, n] },
                   @product.nb_remplissages
                 ),
                 { include_blank: "Choisir une quantité" },
                 class: "admin-select" %>
  </div>
</div>

<%# ---- PRIX ---- %>
<div class="admin-field">
  <label class="admin-label">Prix (€)</label>
  <div style="position:relative;">
    <input type="number"
           name="product[prix_euros]"
           value="<%= @product.prix_cents ? @product.prix_euros.to_i : '' %>"
           min="1" step="1"
           class="admin-input"
           placeholder="32"
           style="padding-right:32px;">
    <span style="position:absolute; right:12px; top:50%; transform:translateY(-50%);
                 color:var(--color-muted); font-size:13px;">€</span>
  </div>
</div>

<%# ---- DESCRIPTION ---- %>
<div class="admin-field">
  <%= f.label :description, "Description", class: "admin-label" %>
  <%= f.text_area :description,
                  class: "admin-textarea",
                  rows: 3,
                  placeholder: "Description courte visible dans la boutique..." %>
</div>

<%# ---- PHOTO ---- %>
<div class="admin-field">
  <label class="admin-label">Photo</label>
  <% if @product.photo.attached? %>
    <div style="margin-bottom:10px; border-radius:12px; overflow:hidden; border:1px solid var(--color-border);">
      <%= image_tag @product.photo, style: "width:100%; height:140px; object-fit:cover; display:block;" %>
    </div>
    <div style="font-size:10px; color:var(--color-muted); margin-bottom:8px;">
      Choisir une nouvelle image pour remplacer.
    </div>
  <% end %>
  <%= f.file_field :photo, accept: "image/*", class: "admin-input", style: "padding:8px; cursor:pointer;" %>
</div>

<%# ---- DISPONIBILITÉ ---- %>
<div class="admin-field">
  <label class="admin-label">Visibilité dans la boutique</label>
  <div style="display:flex; gap:8px; margin-top:4px;">
    <label style="display:flex; align-items:center; gap:8px; cursor:pointer;
                  background:#f6f4f1; border-radius:10px; padding:10px 14px; flex:1;
                  border:1.5px solid <%= @product.actif ? '#2e2926' : '#e2dbd2' %>;">
      <%= f.radio_button :actif, true, style: "accent-color:#2e2926;" %>
      <span style="font-size:12px; color:#2e2926;">Visible</span>
    </label>
    <label style="display:flex; align-items:center; gap:8px; cursor:pointer;
                  background:#f6f4f1; border-radius:10px; padding:10px 14px; flex:1;
                  border:1.5px solid <%= @product.actif ? '#e2dbd2' : '#2e2926' %>;">
      <%= f.radio_button :actif, false, style: "accent-color:#2e2926;" %>
      <span style="font-size:12px; color:#2e2926;">Masqué</span>
    </label>
  </div>
</div>

<%# ============================================================
    JS — Toggle des champs "pack" en fonction du type produit choisi.
    Petit script inline (pas la peine d'un Stimulus pour un cas aussi simple).
    Sur changement du select [data-product-type-select], on affiche
    ou cache le bloc [data-product-pack-fields].
============================================================ %>
<script>
  (function() {
    // Récupère le select de type et le bloc des champs pack
    var typeSelect = document.querySelector('[data-product-type-select]');
    var packFields = document.querySelector('[data-product-pack-fields]');
    if (!typeSelect || !packFields) return;

    // Bascule l'affichage selon la valeur courante.
    // Appelée au chargement (pour aligner l'UI avec la valeur initiale)
    // et à chaque changement.
    function toggle() {
      packFields.style.display = (typeSelect.value === 'pack') ? '' : 'none';
    }
    typeSelect.addEventListener('change', toggle);
    toggle();
  })();
</script>
