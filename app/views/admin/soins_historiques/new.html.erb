<% content_for :title, "Admin — Fiche technique" %>

<%#
  ============================================================
  VUE — Création de la fiche technique après un soin
  Données : @soin_historique (nouveau), @booking
  ============================================================
%>

<div class="admin-wrap">
  <div class="admin-phone">

    <nav class="admin-nav">
      <%= link_to admin_root_path, class: "admin-nav-logo" do %>
        Biche. <span>Admin</span>
      <% end %>
      <%= link_to "← RDV", admin_booking_path(@booking), class: "admin-logout" %>
    </nav>

    <div class="admin-header">
      <div class="admin-header-title">Fiche technique</div>
      <div class="admin-header-sub">
        <%= @booking.user.full_name %> · <%= I18n.l(@booking.date, format: "%-d %B %Y") %>
      </div>
    </div>

    <div class="admin-sec">
      <div class="admin-sec-title"><%= @booking.prestation.nom %></div>

      <%# form_with envoie POST vers /admin/soins_historiques %>
      <%# booking_id est transmis en hidden pour que le controller sache à quel RDV lier la fiche %>
      <%= form_with model: [:admin, @soin_historique], local: true do |f| %>

        <%# Champ caché : lien avec la réservation %>
        <%= f.hidden_field :booking_id, value: @booking.id %>

        <%# ---- PARAMÈTRES TECHNIQUES EN GRILLE ---- %>
        <div class="admin-grid-2">

          <%# Courbure des extensions (ex: C classique, D curl, L curl) %>
          <div class="admin-field">
            <%= f.label :courbure, "Courbure", class: "admin-label" %>
            <%= f.text_field :courbure,
                             class: "admin-input",
                             placeholder: "C, D, L..." %>
          </div>

          <%# Longueur des extensions (ex: 11mm, 11-13mm) %>
          <div class="admin-field">
            <%= f.label :longueur, "Longueur", class: "admin-label" %>
            <%= f.text_field :longueur,
                             class: "admin-input",
                             placeholder: "11-13mm" %>
          </div>

          <%# Épaisseur du fil (ex: 0.07mm, 0.10mm) %>
          <div class="admin-field">
            <%= f.label :epaisseur, "Épaisseur", class: "admin-label" %>
            <%= f.text_field :epaisseur,
                             class: "admin-input",
                             placeholder: "0.07mm" %>
          </div>

          <%# Technique utilisée (ex: Cil à cil, Volume 2D, Volume russe) %>
          <div class="admin-field">
            <%= f.label :technique, "Technique", class: "admin-label" %>
            <%= f.text_field :technique,
                             class: "admin-input",
                             placeholder: "Volume 2D" %>
          </div>

        </div>

        <%# ---- NOTE PERSONNELLE ---- %>
        <%# Observations de Syam : texture des cils naturels, réactions, recommandations %>
        <div class="admin-field">
          <%= f.label :note_syam, "Note personnelle", class: "admin-label" %>
          <%= f.text_area :note_syam,
                          class: "admin-textarea",
                          placeholder: "Texture des cils, réactions, recommandations pour la prochaine fois..." %>
        </div>

        <%= f.submit "Enregistrer la fiche", class: "btn-admin-terminer" %>

      <% end %>
    </div>

  </div>
</div>
