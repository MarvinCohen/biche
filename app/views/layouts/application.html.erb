<!DOCTYPE html>
<html lang="fr">
  <head>
    <!-- Titre de la page (chaque vue peut le personnaliser avec content_for :title) -->
    <title><%= content_for(:title).present? ? "#{content_for(:title)} — Biche." : "Biche. — Technicienne du regard · Bordeaux" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <meta name="description" content="Biche. — Technicienne du regard à Bordeaux. Extensions de cils, rehaussement, soins sur-mesure au Calao Studio.">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Polices Google : Cormorant Garamond (titres élégants) + Inter (texte courant) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

    <%# ============================================================
        FEUILLES DE STYLE DE L'APPLICATION
        On charge chaque CSS directement (au lieu de passer par app.css
        avec des @import qui causaient des 404 avec Propshaft).
        Propshaft sert chaque fichier avec son hash digest correct.

        Ordre IMPORTANT :
        1. application.css → variables + reset + composants globaux
        2. fichiers de pages (home, prestations, etc.)
        Note : desktop.css est chargé EN DERNIER, après yield :head,
        pour que ses media queries écrasent les styles inline des pages
        (ex: <style> dans content_for :head de prestations/index).
    ============================================================ %>
    <%= stylesheet_link_tag "application", "home", "prestations", "bookings",
                            "espace_cliente", "pages", "admin",
                            "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Slot pour les balises head spécifiques à chaque page (meta, scripts, styles inline) -->
    <%= yield :head %>

    <%# ============================================================
        MODE DESKTOP DÉSACTIVÉ TEMPORAIREMENT
        Pour réactiver : décommenter la ligne ci-dessous ET le bloc
        <nav class="nav-desktop"> plus bas dans le body.
    ============================================================ %>
    <%# = stylesheet_link_tag "desktop", "data-turbo-track": "reload" %>
  </head>

  <body>
    <!-- Messages flash (erreurs Devise, confirmations d'actions) -->
    <% if notice.present? %>
      <div class="flash flash--notice"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="flash flash--alert"><%= alert %></div>
    <% end %>

    <%# ============================================================
        NAV DESKTOP HORIZONTALE — DÉSACTIVÉE TEMPORAIREMENT
        Pour réactiver : décommenter ce bloc ET le stylesheet_link_tag
        "desktop" dans le <head>.
    ============================================================ %>
    <%#
    <nav class="nav-desktop" aria-label="Navigation principale desktop">
      <%= link_to "Biche.", root_path, class: "nav-desktop-logo" %>

      <div class="nav-desktop-links">
        <%= link_to "Accueil",      root_path,        class: "nav-desktop-link" %>
        <%= link_to "Prestations",  prestations_path, class: "nav-desktop-link" %>
        <%= link_to "Galerie",      galerie_path,     class: "nav-desktop-link" %>
        <%= link_to "À propos",     about_path,       class: "nav-desktop-link" %>
        <%= link_to "Contact",      contact_path,     class: "nav-desktop-link" %>
        <%= link_to "Shop",         shop_path,        class: "nav-desktop-link" %>
      </div>

      <div class="nav-desktop-cta-wrap">
        <% if user_signed_in? %>
          <%= link_to "Mon espace", espace_cliente_root_path, class: "nav-desktop-account" %>
        <% else %>
          <%= link_to "Connexion", new_user_session_path, class: "nav-desktop-account" %>
        <% end %>
        <%= link_to "Réserver", new_booking_path, class: "nav-desktop-cta" %>
      </div>
    </nav>
    %>

    <!-- Contenu principal de chaque page -->
    <%= yield %>

    <%# ============================================================
        MENU NAVIGATION BURGER — commun à toutes les pages
        Overlay + panel latéral déclenché par .burger au clic
        Le JS ci-dessous écoute tous les clics sur .burger globalement
    ============================================================ %>

    <%# Fond semi-transparent (cliquer dessus ferme le menu) %>
    <div class="nav-overlay" id="nav-overlay"></div>

    <%# Panel menu glissant depuis la droite %>
    <div class="nav-menu" id="nav-menu" aria-hidden="true">

      <%# En-tête : logo + bouton fermer %>
      <div class="nav-menu-header">
        <%= link_to "Biche.", root_path, class: "nav-menu-logo" %>
        <button class="nav-menu-close" id="nav-menu-close" aria-label="Fermer le menu">×</button>
      </div>

      <%# Liens principaux %>
      <div class="nav-menu-links">
        <%= link_to "Accueil",             root_path,          class: "nav-menu-link" %>
        <%= link_to "Prestations & tarifs", prestations_path,  class: "nav-menu-link" %>
        <%= link_to "À propos",            about_path,         class: "nav-menu-link" %>
        <%= link_to "Galerie",             galerie_path,       class: "nav-menu-link" %>
        <%= link_to "Guide morphologie",   morphologie_path,   class: "nav-menu-link" %>
        <%= link_to "Avis",                avis_path,          class: "nav-menu-link" %>

        <hr class="nav-menu-sep">

        <%= link_to "FAQ",                 faq_path,           class: "nav-menu-link" %>
        <%= link_to "Contact",             contact_path,       class: "nav-menu-link" %>
        <%= link_to "Shop",                shop_path,          class: "nav-menu-link" %>

        <hr class="nav-menu-sep">

        <%# Liens selon l'état de connexion %>
        <% if user_signed_in? %>
          <%= link_to "Mon espace cliente", espace_cliente_root_path, class: "nav-menu-link" %>
          <%= link_to "Déconnexion",
                      destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: "nav-menu-link",
                      style: "color: #c47a7a;" %>
        <% else %>
          <%= link_to "Se connecter",   new_user_session_path,      class: "nav-menu-link" %>
          <%= link_to "Créer un compte", new_user_registration_path, class: "nav-menu-link" %>
        <% end %>
      </div>

      <%# Bouton CTA principal %>
      <%= link_to "Prendre rendez-vous", new_booking_path, class: "nav-menu-link-cta" %>

      <%# Pied du menu : infos salon %>
      <div class="nav-menu-footer">
        <div class="nav-menu-footer-text">
          Calao Studio<br>
          37 Rue Lachassaigne · 33000 Bordeaux<br>
          Lun – Sam · 9h – 18h
        </div>
      </div>

    </div>

    <%# Script global — écoute tous les .burger de toutes les pages %>
    <script>
      (function() {
        // Récupère les éléments du menu
        var overlay = document.getElementById('nav-overlay');
        var menu    = document.getElementById('nav-menu');
        var closeBtn = document.getElementById('nav-menu-close');

        // Ouvre le menu
        function openMenu() {
          menu.classList.add('open');
          overlay.classList.add('open');
          menu.setAttribute('aria-hidden', 'false');
          // Cherche le burger actif (la page courante peut en avoir plusieurs)
          document.querySelectorAll('.burger').forEach(function(b) {
            b.classList.add('open');
          });
        }

        // Ferme le menu
        function closeMenu() {
          menu.classList.remove('open');
          overlay.classList.remove('open');
          menu.setAttribute('aria-hidden', 'true');
          document.querySelectorAll('.burger').forEach(function(b) {
            b.classList.remove('open');
          });
        }

        // Délégation d'événement : écoute les clics sur n'importe quel .burger
        // (ils sont dans les vues individuelles, pas dans ce layout)
        document.addEventListener('click', function(e) {
          var burger = e.target.closest('.burger');
          if (burger) {
            menu.classList.contains('open') ? closeMenu() : openMenu();
          }
        });

        // Fermer via le bouton × dans le menu
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);

        // Fermer en cliquant sur l'overlay
        if (overlay) overlay.addEventListener('click', closeMenu);

        // Fermer avec la touche Échap
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') closeMenu();
        });
      })();
    </script>

  </body>
</html>
