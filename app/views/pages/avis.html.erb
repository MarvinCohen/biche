<%# Page Avis — note globale Google, répartition par étoile, cartes d'avis, CTA %>
<% content_for :title, "Avis clients" %>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <% if user_signed_in? %>
          <%= link_to espace_cliente_root_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to "Réserver", new_booking_path, class: "btn-nav" %>
        <div class="burger"><span></span><span></span><span></span></div>
      </div>
    </nav>

    <%# ---- EN-TÊTE ---- %>
    <div class="page-header">
      <div class="ph-blob"></div>
      <div class="ph-tag">Avis</div>
      <h1 class="ph-title">Elles en<br>parlent</h1>
      <p class="ph-intro">Les retours de clientes qui ont confié leur regard à Syam.</p>
    </div>

    <%# ---- SECTION AVIS ---- %>
    <section class="sec">

      <%# Bloc note globale sur fond sombre %>
      <div class="rating-hero">
        <%# Note en grand (4,9) %>
        <div class="rating-score">4,9</div>
        <div class="rating-max">/ 5</div>

        <%# 5 étoiles en beige rosé %>
        <div class="rating-stars">
          <% 5.times do %>
            <svg width="20" height="20" viewBox="0 0 14 14" fill="#b8a898">
              <path d="M7 1l1.8 3.7 4 .6-2.9 2.8.7 4L7 10.2l-3.6 1.9.7-4L1.2 5.3l4-.6z"/>
            </svg>
          <% end %>
        </div>

        <div class="rating-count">Basé sur 47 avis Google</div>

        <%# Badge de vérification Google %>
        <div class="google-badge">
          <svg width="14" height="14" viewBox="0 0 14 14">
            <circle cx="7" cy="7" r="6" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1"/>
            <text x="7" y="10" text-anchor="middle" font-size="8" fill="rgba(255,255,255,0.8)" font-family="serif">G</text>
          </svg>
          Vérifié sur Google Business
        </div>
      </div>

      <%# Barres de répartition des notes (5 → 1 étoile) %>
      <div class="rating-bars">
        <div class="rating-bar-row">
          <div class="rating-bar-label">5</div>
          <div class="rating-bar-track"><div class="rating-bar-fill" style="width: 88%"></div></div>
          <div class="rating-bar-count">41</div>
        </div>
        <div class="rating-bar-row">
          <div class="rating-bar-label">4</div>
          <div class="rating-bar-track"><div class="rating-bar-fill" style="width: 10%"></div></div>
          <div class="rating-bar-count">5</div>
        </div>
        <div class="rating-bar-row">
          <div class="rating-bar-label">3</div>
          <div class="rating-bar-track"><div class="rating-bar-fill" style="width: 2%"></div></div>
          <div class="rating-bar-count">1</div>
        </div>
        <div class="rating-bar-row">
          <div class="rating-bar-label">2</div>
          <div class="rating-bar-track"><div class="rating-bar-fill" style="width: 0%"></div></div>
          <div class="rating-bar-count">0</div>
        </div>
        <div class="rating-bar-row">
          <div class="rating-bar-label">1</div>
          <div class="rating-bar-track"><div class="rating-bar-fill" style="width: 0%"></div></div>
          <div class="rating-bar-count">0</div>
        </div>
      </div>

      <%# Liste des avis clients — données statiques, à dynamiser en DB plus tard %>
      <div class="avis-list">

        <%# Avis 1 — Marie L. %>
        <div class="avis-card">
          <div class="avis-header">
            <div class="avis-user">
              <div class="avis-avatar">M</div>
              <div>
                <div class="avis-name">Marie L.</div>
                <div class="avis-date">Il y a 2 semaines</div>
              </div>
            </div>
            <div class="avis-stars">
              <% 5.times do %>
                <svg width="12" height="12" viewBox="0 0 14 14" fill="#b8a898">
                  <path d="M7 1l1.8 3.7 4 .6-2.9 2.8.7 4L7 10.2l-3.6 1.9.7-4L1.2 5.3l4-.6z"/>
                </svg>
              <% end %>
            </div>
          </div>
          <p class="avis-text">« Syam a un vrai œil d'artiste. Résultat parfait, sur-mesure, et une ambiance douce au studio. Je reviendrai sans hésiter. »</p>
          <span class="avis-tag">Volume léger</span>
        </div>

        <%# Avis 2 — Sophie R. %>
        <div class="avis-card">
          <div class="avis-header">
            <div class="avis-user">
              <div class="avis-avatar" style="background: linear-gradient(145deg, #8a7362, #6b5849)">S</div>
              <div>
                <div class="avis-name">Sophie R.</div>
                <div class="avis-date">Il y a 1 mois</div>
              </div>
            </div>
            <div class="avis-stars">
              <% 5.times do %>
                <svg width="12" height="12" viewBox="0 0 14 14" fill="#b8a898">
                  <path d="M7 1l1.8 3.7 4 .6-2.9 2.8.7 4L7 10.2l-3.6 1.9.7-4L1.2 5.3l4-.6z"/>
                </svg>
              <% end %>
            </div>
          </div>
          <p class="avis-text">« Très professionnelle et à l'écoute. Elle a su adapter la pose à la forme de mes yeux. Le résultat est naturel et durable. »</p>
          <span class="avis-tag">Cil à cil</span>
        </div>

        <%# Avis 3 — Amandine T. %>
        <div class="avis-card">
          <div class="avis-header">
            <div class="avis-user">
              <div class="avis-avatar" style="background: linear-gradient(145deg, #d4bfa0, #b09e7f)">A</div>
              <div>
                <div class="avis-name">Amandine T.</div>
                <div class="avis-date">Il y a 2 mois</div>
              </div>
            </div>
            <div class="avis-stars">
              <% 5.times do %>
                <svg width="12" height="12" viewBox="0 0 14 14" fill="#b8a898">
                  <path d="M7 1l1.8 3.7 4 .6-2.9 2.8.7 4L7 10.2l-3.6 1.9.7-4L1.2 5.3l4-.6z"/>
                </svg>
              <% end %>
            </div>
          </div>
          <p class="avis-text">« J'ai testé le rehaussement pour la première fois et je ne m'y attendais pas à un tel résultat. Cadre agréable, Syam explique tout. »</p>
          <span class="avis-tag">Rehaussement</span>
        </div>

      </div>

      <%# Bouton vers tous les avis Google %>
      <div class="google-cta">
        <a href="#" class="google-btn">Voir tous les avis →</a>
      </div>

      <%# Encadré "Laisser un avis" — invite les clientes à partager leur expérience %>
      <div class="laisser-avis">
        <div class="laisser-title">Vous êtes cliente ?</div>
        <p class="laisser-sub">Partagez votre expérience pour aider d'autres personnes à découvrir l'atelier.</p>
        <a href="#" class="laisser-btn">Laisser un avis Google</a>
      </div>

    </section>

    <%# ---- FOOTER ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-tag">Technicienne du regard · Bordeaux</div>
      <div class="footer-links">
        <%= link_to "À propos", about_path %>
        <%= link_to "FAQ",      faq_path %>
        <%= link_to "Shop",     shop_path %>
        <%= link_to "Contact",  contact_path %>
      </div>
      <div class="footer-copy">© 2026 Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>
