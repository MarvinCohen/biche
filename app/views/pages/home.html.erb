<% content_for :title, "Accueil" %>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <% if user_signed_in? %>
          <%# Icône compte pour les clientes connectées %>
          <%= link_to espace_cliente_root_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to "Réserver", new_booking_path, class: "btn-nav" %>
        <div class="burger"><span></span><span></span><span></span></div>
      </div>
    </nav>

    <%# ---- HERO ---- %>
    <section class="hero">
      <div class="hero-big-b">B.</div>
      <div class="hero-accent"></div>
      <div class="hero-content">
        <%# Photo réelle de l'oeil — remplace l'illustration SVG précédente %>
        <div class="hero-photo">
          <%= image_tag "hero-eye.jpg", alt: "Regard sublimé par Biche.", class: "hero-eye-img" %>
        </div>
        <p class="hero-sup">Technicienne du regard · Bordeaux</p>
        <h1 class="hero-h1">L'art du regard,<br>sur mesure.</h1>
        <p class="hero-p">Du naturel au plus intense,<br>selon tes envies.</p>
        <%# Bouton principal : réservation %>
        <%= link_to "Réserve ton créneau", new_booking_path, class: "cta-primary" %>
        <%# Bouton secondaire : guide morphologique (évite la redondance avec la section prestations) %>
        <div style="margin-top:12px">
          <%= link_to "Guide morphologique", morphologie_path, class: "cta-ghost" %>
        </div>
      </div>
    </section>

    <%# ---- DERNIÈRE VIDÉO TIKTOK ---- %>
    <%# Affichée juste après le hero pour maximiser la visibilité.
        Le partial ne rend rien si @tiktok_url est vide → pas de section vide. %>
    <%= render "shared/tiktok_embed", tiktok_url: @tiktok_url %>

    <%# ---- PROGRAMME FIDÉLITÉ (en premier pour inciter à créer un compte) ---- %>
    <section class="sec sec-nude">
      <div class="fid-block">
        <p class="fid-mini">Fidélité</p>
        <h2 class="fid-title">Un regard fidèle,<br>mérite récompense</h2>
        <p class="fid-sub">Gagnez des points à chaque visite.<br>Accédez à votre espace personnel.</p>
        <% if user_signed_in? %>
          <%= link_to "Mon espace cliente", espace_cliente_root_path, class: "fid-btn" %>
        <% else %>
          <%= link_to "Créer mon compte", new_user_registration_path, class: "fid-btn" %>
        <% end %>
      </div>
    </section>

    <%# ---- PRESTATIONS CAROUSEL ---- %>
    <section class="sec sec-cream">
      <p class="s-tag">Prestations</p>
      <h2 class="s-h2">Sublimer votre regard</h2>
      <p class="s-sub">Des soins pensés sur-mesure, du plus doux au plus intense.</p>
      <div class="swipe-hint">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8 3 L4 7 L8 11" stroke="#b8a898" stroke-width="1.5" stroke-linecap="round"/></svg>
        Glissez pour découvrir
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M6 3 L10 7 L6 11" stroke="#b8a898" stroke-width="1.5" stroke-linecap="round"/></svg>
      </div>
      <div style="margin: 0 -20px">
        <div class="carousel" id="car-prestations">
          <%#
            Mapping prestation.categorie → galerie.categorie
            Permet de trouver automatiquement une photo de galerie correspondante
          %>
          <%#
            Correspondance catégorie prestation → catégorie galerie.
            Toutes les catégories de prestations sont couvertes.
          %>
          <% cat_map = { 'extensions'   => 'cil-a-cil',
                         'rehaussement' => 'rehaussement',
                         'sourcils'     => 'sourcils',
                         'retouche'     => 'cil-a-cil',
                         'depose'       => 'cil-a-cil' } %>

          <%# Première photo dispo dans toute la galerie — utilisée en dernier recours %>
          <% premiere_photo_galerie = @galerie_par_categorie.values.first %>

          <% @prestations.each do |prestation| %>
            <div class="presta-card">
              <div class="presta-img">
                <% if prestation.photo.attached? %>
                  <%# Priorité 1 : photo uploadée directement sur la prestation %>
                  <%= image_tag prestation.photo, alt: prestation.nom, class: "presta-photo" %>
                <% elsif (galerie_photo = @galerie_par_categorie[cat_map[prestation.categorie]]) %>
                  <%# Priorité 2 : première photo de galerie de la catégorie correspondante %>
                  <%= image_tag galerie_photo.image, alt: prestation.nom, class: "presta-photo" %>
                <% elsif premiere_photo_galerie %>
                  <%# Priorité 3 : n'importe quelle photo de galerie si pas de match de catégorie %>
                  <%= image_tag premiere_photo_galerie.image, alt: prestation.nom, class: "presta-photo" %>
                <% else %>
                  <%# Priorité 4 : SVG placeholder si la galerie est vide %>
                  <svg width="100" height="60" viewBox="0 0 100 60" fill="none">
                    <path d="M5 35 Q25 10 50 35 Q75 10 95 35" stroke="#5e5550" stroke-width="1.5" fill="none"/>
                  </svg>
                <% end %>
              </div>
              <div class="presta-name"><%= prestation.nom %></div>
              <div class="presta-desc"><%= prestation.description %></div>
              <div class="presta-meta"><%= prestation.duree_formatee %> · dès <%= number_to_currency(prestation.prix_euros, unit: "€", format: "%n%u", precision: 0) %></div>
              <%= link_to "Je réserve", new_booking_path(prestation_id: prestation.id), class: "presta-btn" %>
            </div>
          <% end %>
        </div>
        <div class="carousel-controls">
          <div class="car-arrow" onclick="scrollCar('car-prestations', -1)">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3 L5 8 L10 13" stroke="#2e2926" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div class="car-dots" id="dots-prestations">
            <% @prestations.each_with_index do |_, i| %>
              <div class="car-dot <%= i.zero? ? 'active' : '' %>"></div>
            <% end %>
          </div>
          <div class="car-arrow" onclick="scrollCar('car-prestations', 1)">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3 L11 8 L6 13" stroke="#2e2926" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
        </div>
      </div>
    </section>

    <%# ---- SHOP — BEST-SELLERS ---- %>
    <section class="sec">
      <div class="shop-block">

        <%# Cercle décoratif en arrière-plan %>
        <div class="shop-deco"></div>

        <p class="shop-mini">Boutique</p>
        <h2 class="shop-title">Nos best-sellers</h2>
        <p class="shop-sub">Prolongez votre soin<br>entre les visites.</p>

        <%# Carousel auto-scrollant — défile automatiquement toutes les 2.5s %>
        <div class="shop-carousel" id="car-shop">
          <% @produits.each do |produit| %>
            <%# data-original marque les cards d'origine pour les distinguer des clones JS %>
            <div class="shop-card" data-original="true">
              <%# Icône selon le type de produit %>
              <div class="shop-card-ico">
                <% if produit.type_produit == 'carte_cadeau' %>
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <rect x="2" y="9" width="18" height="12" rx="2" stroke="rgba(255,255,255,0.7)" stroke-width="1.3"/>
                    <path d="M1 9h20" stroke="rgba(255,255,255,0.7)" stroke-width="1.3" stroke-linecap="round"/>
                    <path d="M11 9V21" stroke="rgba(255,255,255,0.7)" stroke-width="1.3"/>
                    <path d="M11 9c0-3-4-3-4 0s4 0 4 0z" stroke="rgba(255,255,255,0.7)" stroke-width="1.3"/>
                    <path d="M11 9c0-3 4-3 4 0s-4 0-4 0z" stroke="rgba(255,255,255,0.7)" stroke-width="1.3"/>
                  </svg>
                <% elsif produit.type_produit == 'pack' %>
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <rect x="3" y="3" width="16" height="16" rx="3" stroke="rgba(255,255,255,0.7)" stroke-width="1.3"/>
                    <path d="M7 11h8M11 7v8" stroke="rgba(255,255,255,0.7)" stroke-width="1.3" stroke-linecap="round"/>
                  </svg>
                <% else %>
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <path d="M8 3h6l2 4H6L8 3z" stroke="rgba(255,255,255,0.7)" stroke-width="1.3" stroke-linejoin="round"/>
                    <rect x="5" y="7" width="12" height="12" rx="2" stroke="rgba(255,255,255,0.7)" stroke-width="1.3"/>
                    <path d="M9 12h4" stroke="rgba(255,255,255,0.7)" stroke-width="1.3" stroke-linecap="round"/>
                  </svg>
                <% end %>
              </div>
              <div class="shop-card-name"><%= produit.nom %></div>
              <div class="shop-card-price"><%= number_to_currency(produit.prix_cents / 100.0, unit: "€", format: "%n%u", precision: 0) %></div>
            </div>
          <% end %>
        </div>

        <%= link_to "Découvrir la boutique", shop_path, class: "shop-btn" %>
      </div>
    </section>

    <%# ---- LOCALISATION ---- %>
    <section class="sec">
      <p class="s-tag">Nous trouver</p>
      <h2 class="s-h2">Au cœur de Bordeaux</h2>
      <%# Carte Google Maps embarquée — Calao Studio, 37 rue Lachassaigne, Bordeaux %>
      <%# Pas besoin d'API key pour l'embed basique %>
      <%# Carte Google Maps embarquée — Calao Studio, 37 rue Lachassaigne, Bordeaux %>
      <div class="map-embed">
        <iframe
          src="https://maps.google.com/maps?q=37+Rue+Lachassaigne,+33000+Bordeaux&t=&z=15&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="220"
          style="border: 0; display: block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Calao Studio — 37 Rue Lachassaigne, Bordeaux">
        </iframe>
      </div>
      <%# Lien externe vers Google Maps (les contrôles de l'iframe sont coupés par le blob) %>
      <%# Lien vers Google Maps pour l'itinéraire %>
      <a href="https://maps.google.com/?q=37+Rue+Lachassaigne,+33000+Bordeaux"
         target="_blank"
         rel="noopener noreferrer"
         class="map-label">
        ↗ Ouvrir dans Google Maps
      </a>
      <div class="addr-line">
        <b>Calao Studio</b>
        37 Rue Lachassaigne<br>33000 Bordeaux
      </div>
    </section>

    <%# ---- FOOTER ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-tag">Technicienne du regard · Bordeaux</div>
      <div class="footer-links">
        <%= link_to "FAQ", faq_path %>
        <%= link_to "Avis", avis_path %>
        <%= link_to "Shop", shop_path %>
        <%= link_to "Contact", contact_path %>
      </div>
      <div class="footer-copy">© <%= Date.today.year %> Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>

<%# ---- JAVASCRIPT — carrousel ---- %>
<% content_for :head do %>
  <script>
    // scrollCar — défile d'une card à la fois en mesurant la largeur réelle
    function scrollCar(id, dir) {
      const car = document.getElementById(id);
      // Largeur réelle de la première card (évite les valeurs codées en dur)
      const cardWidth = car.firstElementChild ? car.firstElementChild.offsetWidth + 14 : 274;
      car.scrollBy({ left: dir * cardWidth, behavior: 'smooth' });
    }

    // updateDots — trouve la card la plus proche du centre du carousel et active le dot correspondant
    function updateDots(car, dots) {
      const carCenter = car.getBoundingClientRect().left + car.offsetWidth / 2;
      let closestIndex = 0;
      let closestDist  = Infinity;
      [...car.children].forEach((child, i) => {
        const rect      = child.getBoundingClientRect();
        const childCenter = rect.left + rect.width / 2;
        const dist      = Math.abs(childCenter - carCenter);
        if (dist < closestDist) { closestDist = dist; closestIndex = i; }
      });
      dots.forEach((d, i) => d.classList.toggle('active', i === closestIndex));
    }

    // turbo:load couvre aussi le retour depuis le cache Turbo (navigation retour/avant)
    // DOMContentLoaded couvre le premier chargement classique
    function initHome() {
      // Dots du carousel prestations
      const car  = document.getElementById('car-prestations');
      const dots = document.querySelectorAll('#dots-prestations .car-dot');
      if (car) car.addEventListener('scroll', () => updateDots(car, dots));

      // Auto-scroll infini du carousel shop — une card à la fois, défilement continu
      const shopCar = document.getElementById('car-shop');
      if (shopCar) {
        // ---- Protection contre les doubles initialisations (Turbo cache) ----
        // Si un interval tourne déjà, on l'annule avant d'en créer un nouveau
        if (shopCar._scrollInterval) clearInterval(shopCar._scrollInterval);

        // On supprime les clones précédents (ajoutés lors d'un passage précédent)
        // Les items originaux sont marqués data-original="true" par Rails (voir erb)
        [...shopCar.children].forEach(item => {
          if (!item.dataset.original) item.remove();
        });
        // Remet le scroll à zéro pour repartir proprement
        shopCar.scrollLeft = 0;

        let paused = false;

        // ---- Duplication des items pour un défilement sans saut ----
        // On clone les items originaux et on les ajoute à la fin
        // Ainsi quand on arrive à la "moitié", on repart silencieusement au début
        const originalItems = [...shopCar.children];
        originalItems.forEach(item => shopCar.appendChild(item.cloneNode(true)));

        // Pause quand l'utilisateur touche le carousel
        shopCar.addEventListener('touchstart', () => { paused = true; });
        shopCar.addEventListener('touchend',   () => { setTimeout(() => paused = false, 3000); });

        shopCar._scrollInterval = setInterval(() => {
          if (paused) return;

          // Largeur exacte d'une card = largeur visible du carousel (pas de gap)
          const cardWidth = shopCar.firstElementChild
            ? shopCar.firstElementChild.offsetWidth
            : shopCar.clientWidth;

          // Avance d'une card avec animation
          shopCar.scrollBy({ left: cardWidth, behavior: 'smooth' });

          // Quand on a parcouru tous les items originaux (= moitié du scroll total),
          // on remet silencieusement au début — l'utilisateur ne voit pas le saut
          const halfWidth = (shopCar.scrollWidth / 2);
          setTimeout(() => {
            if (shopCar.scrollLeft >= halfWidth - 10) {
              shopCar.scrollTo({ left: shopCar.scrollLeft - halfWidth, behavior: 'instant' });
            }
          }, 600); // On attend que l'animation smooth soit terminée
        }, 2500);
      }
    }

    document.addEventListener('DOMContentLoaded', initHome);
    document.addEventListener('turbo:load', initHome);
  </script>
<% end %>
