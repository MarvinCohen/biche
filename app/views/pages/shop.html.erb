<%# Page Shop — CSS exact de la maquette injecté dans le head pour fidélité pixel-perfect %>
<% content_for :title, "Shop" %>

<%# Injection du CSS exact de la maquette biche-shop-v2.html dans le <head> %>
<% content_for :head do %>
<style>
  /* Reprise exacte des styles de la maquette biche-shop-v2.html */

  /* Navigation — positionnée en absolu pour superposition sur le header */
  /* Nav alignée sur le global (beige #f5ede2). Pas de backdrop-filter : */
  /* trop coûteux sur mobile (saccades au scroll iOS/Android). */
  .nav { background: #f5ede2; padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; position: absolute; top: 0; left: 0; right: 0; z-index: 10; border-bottom: 0.5px solid #e4ddd6; }
  .logo-mini { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #2e2926; font-style: italic; font-weight: 500; text-decoration: none; }
  .nav-right { display: flex; gap: 12px; align-items: center; }
  .burger { display: flex; flex-direction: column; gap: 4px; cursor: pointer; width: 22px; }
  .burger span { height: 1.5px; background: #2e2926; border-radius: 1px; display: block; }
  .burger span:last-child { width: 60%; }
  .btn-nav { background: #2e2926; color: #fff; border: none; border-radius: 30px; padding: 9px 18px; font-size: 11px; font-weight: 500; letter-spacing: 1px; cursor: pointer; text-transform: uppercase; font-family: inherit; text-decoration: none; }

  /* Header — grand padding-top pour compenser la nav absolue */
  /* Fond aligné sur le .page-header global (var(--color-nude) = #f5ede2) */
  /* pour rester cohérent avec les autres pages du site (prestations, faq…) */
  .page-header { position: relative; padding: 110px 24px 44px; text-align: center; background: #f5ede2; overflow: hidden; }
  .ph-blob { position: absolute; top: 80px; right: -40px; width: 130px; height: 130px; background: #9a8e86; border-radius: 62% 38% 54% 46% / 48% 52% 48% 52%; opacity: 0.2; z-index: 1; }
  .ph-blob-2 { position: absolute; bottom: -20px; left: -30px; width: 100px; height: 100px; background: #7a7470; border-radius: 50%; opacity: 0.15; z-index: 1; }
  .ph-tag { position: relative; z-index: 2; font-size: 10px; letter-spacing: 4px; color: #7a6e66; text-transform: uppercase; margin-bottom: 14px; }
  .ph-title { position: relative; z-index: 2; font-family: 'Cormorant Garamond', serif; font-size: 42px; color: #2e2926; line-height: 1.1; margin-bottom: 14px; font-weight: 400; }
  .ph-intro { position: relative; z-index: 2; font-size: 13px; color: #6e6560; line-height: 1.7; max-width: 300px; margin: 0 auto; }

  /* Menu navigation interne sticky avec 3 onglets */
  .shop-nav { background: #fff; border-bottom: 1px solid #e4ddd6; padding: 0; position: sticky; top: 0; z-index: 9; }
  .shop-nav-inner { display: flex; overflow-x: auto; scrollbar-width: none; padding: 0 20px; }
  .shop-nav-inner::-webkit-scrollbar { display: none; }
  .shop-nav-item { flex-shrink: 0; padding: 14px 16px; font-size: 11px; color: #8e8480; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; border-bottom: 2px solid transparent; white-space: nowrap; font-weight: 500; transition: all 0.2s; font-family: inherit; background: none; border-top: none; border-left: none; border-right: none; }
  .shop-nav-item.active { color: #2e2926; border-bottom-color: #2e2926; }
  .shop-nav-item:hover { color: #2e2926; }

  /* Sections — fond blanc par défaut, variantes disponibles */
  .sec { padding: 40px 20px; background: #fff; }
  .sec-alt { background: #f7f5f2; }
  .sec-cream { background: #f6f4f1; }
  .s-tag { font-size: 10px; letter-spacing: 4px; color: #988e88; text-transform: uppercase; margin-bottom: 10px; text-align: center; }
  .s-h2 { font-family: 'Cormorant Garamond', serif; font-size: 28px; color: #2e2926; text-align: center; margin-bottom: 6px; font-weight: 400; }
  .s-sub { font-size: 12px; color: #8e8480; text-align: center; line-height: 1.6; margin-bottom: 26px; }

  /* Carte cadeau — visuel de prévisualisation */
  /* Dégradé chaud brun + effet de profondeur avec les cercles décoratifs */
  .gift-visual {
    background: linear-gradient(135deg, #1e1b19 0%, #3a3330 50%, #5e5a56 100%);
    border-radius: 20px;
    padding: 22px 22px 20px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
    /* Ombre portée pour effet de carte physique */
    box-shadow: 0 8px 32px rgba(46,41,38,0.35), 0 2px 8px rgba(0,0,0,0.2);
  }

  /* Bordure intérieure fine dorée — effet carte premium */
  .gift-visual::after {
    content: '';
    position: absolute;
    inset: 6px;
    border-radius: 14px;
    border: 0.5px solid rgba(184,168,152,0.25);
    pointer-events: none;
  }

  /* Grand cercle décoratif en haut à droite */
  .gift-visual-circle-1 {
    position: absolute;
    top: -30px; right: -30px;
    width: 110px; height: 110px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184,168,152,0.15) 0%, transparent 70%);
  }

  /* Petit cercle décoratif en bas à gauche */
  .gift-visual-circle-2 {
    position: absolute;
    bottom: -20px; left: -20px;
    width: 70px; height: 70px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184,168,152,0.1) 0%, transparent 70%);
  }

  /* Reflet brillant animé qui glisse sur la carte */
  @keyframes shimmer {
    0%   { transform: translateX(-120%) skewX(-15deg); }
    100% { transform: translateX(300%) skewX(-15deg); }
  }
  .gift-visual-shimmer {
    position: absolute;
    top: 0; left: 0;
    width: 40%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
    animation: shimmer 3.5s ease-in-out infinite;
  }

  /* Contenu de la carte — au-dessus des décorations */
  .gift-visual-inner { position: relative; z-index: 1; }

  /* En-tête de la carte : logo à gauche, puce décorative à droite */
  .gift-visual-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 18px;
  }

  .gift-visual-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    color: rgba(255,255,255,0.9);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  /* Puce décorative dorée en haut à droite (imite les cartes bancaires) */
  .gift-visual-chip {
    width: 28px; height: 20px;
    border-radius: 4px;
    background: linear-gradient(135deg, #c8b89a, #a89078);
    opacity: 0.7;
    border: 0.5px solid rgba(255,255,255,0.2);
  }

  /* Montant — élément central de la carte */
  .gift-visual-amount {
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px;
    color: #fff;
    font-weight: 300;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
    /* line-height plus généreux pour éviter que les descendants (5, 9, g...)
       débordent sur le label "Carte cadeau" en dessous */
    line-height: 1.15;
  }

  /* "Pour Prénom" — affiché au-dessus du montant sur le visuel de la carte */
  .gift-visual-pour {
    font-size: 10px;
    letter-spacing: 1.5px;
    color: rgba(184,168,152,0.65);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .gift-visual-label {
    font-size: 9px;
    letter-spacing: 3px;
    color: rgba(184,168,152,0.7);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  /* Séparateur élégant */
  .gift-visual-sep {
    height: 0.5px;
    background: linear-gradient(90deg, transparent, rgba(184,168,152,0.4), transparent);
    margin-bottom: 12px;
  }

  /* Pied de carte : validité et code */
  .gift-visual-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .gift-visual-valid {
    font-size: 9px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 1.6;
  }

  .gift-visual-code {
    font-size: 9px;
    color: rgba(184,168,152,0.5);
    letter-spacing: 2.5px;
    text-align: right;
  }

  /* Carte cadeau — formulaire de commande */
  .gift-card-box { background: #2e2926; border-radius: 24px; padding: 30px 22px; position: relative; overflow: hidden; }
  .gift-card-box::before { content: ''; position: absolute; top: -40px; right: -40px; width: 160px; height: 160px; border-radius: 50%; background: rgba(184,168,152,0.08); }
  .gift-card-box::after { content: ''; position: absolute; bottom: -30px; left: -30px; width: 100px; height: 100px; border-radius: 50%; background: rgba(184,168,152,0.06); }
  .gift-badge { display: inline-block; background: #b8a898; color: #2e2926; padding: 5px 14px; border-radius: 20px; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; font-weight: 500; position: relative; z-index: 1; }
  .gift-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: #fff; margin-bottom: 10px; line-height: 1.3; position: relative; z-index: 1; }
  .gift-sub { font-size: 12px; color: rgba(255,255,255,0.65); line-height: 1.6; margin-bottom: 22px; position: relative; z-index: 1; }
  .gift-amounts { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; position: relative; z-index: 1; }
  .gift-amount { padding: 9px 18px; border-radius: 30px; border: 1px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.75); font-size: 13px; font-family: 'Cormorant Garamond', serif; cursor: pointer; background: transparent; }
  .gift-amount.selected { background: rgba(255,255,255,0.12); border-color: #b8a898; color: #b8a898; }
  .gift-custom { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; position: relative; z-index: 1; }
  .gift-custom-label { font-size: 11px; color: rgba(255,255,255,0.55); white-space: nowrap; }
  .gift-custom-input { flex: 1; padding: 10px 14px; border: 1px solid rgba(255,255,255,0.18); border-radius: 12px; background: rgba(255,255,255,0.07); color: #fff; font-size: 13px; font-family: inherit; }
  .gift-custom-input::placeholder { color: rgba(255,255,255,0.25); }
  .gift-btn { background: #b8a898; color: #2e2926; border: none; border-radius: 30px; padding: 13px 28px; font-size: 11px; font-weight: 500; letter-spacing: 1.5px; cursor: pointer; text-transform: uppercase; font-family: inherit; position: relative; z-index: 1; }

  /* Packs multi-visites */
  .packs-list { display: flex; flex-direction: column; gap: 14px; }
  .pack-card { border: 1px solid #e2dbd2; border-radius: 22px; overflow: hidden; background: #fff; }
  .pack-card.featured { border: 1.5px solid #2e2926; }
  .pack-header { padding: 20px 20px 14px; }
  .pack-badge { display: inline-block; background: #2e2926; color: #fff; padding: 4px 12px; border-radius: 14px; font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px; font-weight: 500; }
  .pack-badge.gold { background: #b8a898; color: #2e2926; }
  .pack-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #2e2926; margin-bottom: 6px; }
  .pack-desc { font-size: 12px; color: #6e6560; line-height: 1.6; margin-bottom: 14px; }
  .pack-includes { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
  .pack-include-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #4e4a46; }
  .pack-check { width: 16px; height: 16px; border-radius: 50%; background: #f6f4f1; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .pack-footer { padding: 16px 20px; background: #f6f4f1; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #e2dbd2; }
  .pack-price { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: #2e2926; }
  .pack-price-old { font-size: 11px; color: #a09890; text-decoration: line-through; }
  .pack-economy { font-size: 10px; color: #7a9a6a; letter-spacing: 0.5px; font-weight: 500; }
  /* text-decoration: none — sinon les <a> Rails (link_to) gardent le soulignement par défaut */
  .pack-btn { background: #2e2926; color: #fff; border: none; border-radius: 30px; padding: 11px 22px; font-size: 11px; font-weight: 500; letter-spacing: 1.2px; cursor: pointer; text-transform: uppercase; font-family: inherit; text-decoration: none; display: inline-block; }

  /* Produits routine */
  .products-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  /* grid-auto-rows: 1fr — toutes les lignes de la grille ont la même hauteur → toutes les 4 cards identiques */
  .products-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; grid-auto-rows: 1fr; }
  /* flex colonne sur la card pour pousser le footer en bas quelle que soit la hauteur */
  .product-card { background: #fff; border: 1px solid #e2dbd2; border-radius: 20px; overflow: hidden; display: flex; flex-direction: column; }
  /* Zone image produit — hauteur fixe, contient photo Active Storage ou placeholder SVG */
  .product-img { height: 130px; flex-shrink: 0; overflow: hidden; background: #f0ede8;
                 display: flex; align-items: center; justify-content: center; }
  /* flex: 1 sur product-body — prend tout l'espace restant après l'image */
  .product-body { padding: 12px 14px; display: flex; flex-direction: column; flex: 1; }
  .product-name { font-family: 'Cormorant Garamond', serif; font-size: 16px; color: #2e2926; margin-bottom: 3px; }
  /* flex: 1 sur la desc — pousse le footer tout en bas de la card */
  .product-desc { font-size: 10px; color: #8e8480; line-height: 1.5; margin-bottom: 10px; flex: 1; }
  .product-footer { display: flex; justify-content: space-between; align-items: center; }
  .product-price { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: #2e2926; }
  /* text-decoration: none — sinon les <a> Rails (link_to) gardent le soulignement par défaut */
  .product-btn { background: #2e2926; color: #fff; border: none; border-radius: 16px; padding: 7px 14px; font-size: 10px; cursor: pointer; letter-spacing: 0.8px; text-transform: uppercase; font-family: inherit; font-weight: 500; text-decoration: none; display: inline-block; }

  /* Footer — fond très sombre */
  .footer { background: #241e1c; padding: 36px 20px 28px; text-align: center; }
  .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 36px; color: #b8a898; font-style: italic; margin-bottom: 10px; }
  .footer-tag { font-size: 10px; letter-spacing: 2px; color: rgba(255,255,255,0.35); text-transform: uppercase; margin-bottom: 18px; }
  .footer-links { display: flex; justify-content: center; gap: 18px; flex-wrap: wrap; margin-bottom: 16px; }
  .footer-links a, .footer-links span { font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 1px; text-transform: uppercase; cursor: pointer; text-decoration: none; }
  .footer-copy { font-size: 9px; color: rgba(255,255,255,0.25); letter-spacing: 1px; }
</style>
<% end %>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <div class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <%# Adaptation Rails : icône profil selon l'état de connexion Devise %>
        <% if user_signed_in? %>
          <%= link_to espace_cliente_root_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to "Réserver", new_booking_path, class: "btn-nav" %>
        <div class="burger"><span></span><span></span><span></span></div>
      </div>
    </div>

    <%# ---- EN-TÊTE ---- %>
    <div class="page-header">
      <div class="ph-blob"></div>
      <div class="ph-blob-2"></div>
      <div class="ph-tag">Boutique</div>
      <div class="ph-title">Shop</div>
      <div class="ph-intro">Cartes cadeaux, packs multi-visites et produits pour votre routine beauté.</div>
    </div>

    <%# ---- MENU NAVIGATION INTERNE ---- %>
    <div class="shop-nav">
      <div class="shop-nav-inner">
        <button class="shop-nav-item active" onclick="scrollToSection('section-gift', this)">Cartes cadeaux</button>
        <button class="shop-nav-item" onclick="scrollToSection('section-packs', this)">Packs</button>
        <button class="shop-nav-item" onclick="scrollToSection('section-products', this)">Produits routine</button>
      </div>
    </div>

    <%# ---- CARTES CADEAUX ---- %>
    <div class="sec" id="section-gift">
      <div class="s-tag">Offrir</div>
      <div class="s-h2">Cartes cadeaux</div>
      <div class="s-sub">Offrez une expérience Biche. Envoi par email instantané, valable 1 an.</div>

      <%# Aperçu visuel de la carte cadeau %>
      <div class="gift-visual">
        <%# Éléments décoratifs de fond %>
        <div class="gift-visual-circle-1"></div>
        <div class="gift-visual-circle-2"></div>
        <%# Reflet animé qui glisse sur la carte — effet premium %>
        <div class="gift-visual-shimmer"></div>

        <%# Contenu de la carte — au-dessus des décorations (z-index: 1) %>
        <div class="gift-visual-inner">

          <%# En-tête : logo Biche. + puce décorative %>
          <div class="gift-visual-header">
            <div class="gift-visual-logo">Biche.</div>
            <div class="gift-visual-chip"></div>
          </div>

          <%# Nom du destinataire — mis à jour en temps réel (caché si vide) %>
          <div class="gift-visual-pour" id="gift-preview-pour" style="display:none;">
            Pour <span id="gift-preview-nom"></span>
          </div>

          <%# Montant mis à jour en temps réel par le JS — id ciblé %>
          <div class="gift-visual-amount" id="gift-preview-amount">65€</div>
          <div class="gift-visual-label">Carte cadeau</div>

          <%# Séparateur élégant %>
          <div class="gift-visual-sep"></div>

          <%# Pied de carte %>
          <div class="gift-visual-footer">
            <div class="gift-visual-valid">
              Valable 1 an<br>Toutes prestations
            </div>
            <div class="gift-visual-code">BICHE·2026·XXXX</div>
          </div>

        </div>
      </div>

      <%# Formulaire de commande %>
      <div class="gift-card-box">
        <div class="gift-badge">Carte cadeau</div>
        <div class="gift-title">Offrir un soin<br>du regard</div>
        <div class="gift-sub">Valable sur toutes les prestations de l'atelier. La destinataire choisit sa date.</div>
        <div class="gift-amounts">
          <div class="gift-amount" onclick="selectAmount(this)">55€</div>
          <div class="gift-amount selected" onclick="selectAmount(this)">65€</div>
          <div class="gift-amount" onclick="selectAmount(this)">80€</div>
          <div class="gift-amount" onclick="selectAmount(this)">95€</div>
        </div>
        <%# Champ destinataire — mis à jour en temps réel sur le visuel de la carte %>
        <div class="gift-custom" style="margin-bottom:14px;">
          <div class="gift-custom-label">Pour :</div>
          <input class="gift-custom-input"
                 type="text"
                 id="gift-input-nom"
                 placeholder="Prénom de la personne"
                 maxlength="30"/>
        </div>

        <div class="gift-custom">
          <div class="gift-custom-label">Montant libre :</div>
          <%# type="text" + inputmode="numeric" : clavier numérique sur mobile,
              mais le scroll ne change plus la valeur (comportement type="number" indésirable) %>
          <input class="gift-custom-input"
                 type="text"
                 id="gift-input-montant"
                 inputmode="numeric"
                 pattern="[0-9]*"
                 placeholder="Ex : 120"/>
        </div>
        <%# Le bouton collecte le montant sélectionné + le nom et navigue vers orders#new %>
        <button class="gift-btn" onclick="soumettreCarte(event)">Offrir cette carte →</button>
      </div>
    </div>

    <%# ============================================================
        PACKS DE REMPLISSAGE — affichage filtré par type de pose
        Sélecteur en pills (Cil à cil, Volume léger, etc.) → on n'affiche
        que les 3 packs (3 / 6 / 9 remplissages) de la pose sélectionnée.
        Par défaut, la première pose est active. Cas vide (aucun pack en BDD)
        géré en amont par le `if`.
    ============================================================ %>
    <% if @packs_par_pose.any? %>
      <%# Style local des pills + des 3 cards (réutilise le DS Biche.) %>
      <style>
        /* Bar des pills de filtre par pose */
        .pose-pills {
          display: flex;
          gap: 8px;
          overflow-x: auto;
          padding: 4px 4px 16px;
          margin: 0 -4px 8px;
          scrollbar-width: none;
        }
        .pose-pills::-webkit-scrollbar { display: none; }
        .pose-pill {
          flex: 0 0 auto;
          padding: 8px 16px;
          border-radius: 20px;
          background: #fff;
          border: 1px solid var(--color-border, #e2dbd2);
          font-size: 12px;
          color: var(--color-dark, #2e2926);
          cursor: pointer;
          white-space: nowrap;
          transition: all 0.18s ease;
        }
        .pose-pill.active {
          background: var(--color-dark, #2e2926);
          color: #fff;
          border-color: var(--color-dark, #2e2926);
        }
        /* Groupe de 3 cards par pose — masqué par défaut, affiché si .active */
        .pose-group { display: none; }
        .pose-group.active { display: block; }
      </style>

      <div class="sec sec-alt" id="section-packs">
        <div class="s-tag">Fidélité</div>
        <div class="s-h2">Packs de remplissage</div>
        <div class="s-sub">Choisissez votre type de pose, puis votre formule.</div>

        <%# ---- PILLS DE FILTRE PAR POSE ---- %>
        <%# data-pose-pill : sélecteur pour le JS. Valeur = id de la prestation. %>
        <div class="pose-pills">
          <% @packs_par_pose.keys.each_with_index do |pose, idx| %>
            <button class="pose-pill <%= 'active' if idx.zero? %>"
                    data-pose-pill="<%= pose.id %>">
              <%= pose.nom %>
            </button>
          <% end %>
        </div>

        <%# ---- GROUPES DE PACKS PAR POSE (un seul affiché à la fois) ---- %>
        <% @packs_par_pose.each_with_index do |(pose, packs), idx| %>
          <%# data-pose-group : sélecteur pour le JS, doit matcher data-pose-pill %>
          <div class="pose-group <%= 'active' if idx.zero? %>"
               data-pose-group="<%= pose.id %>">
            <div class="packs-list">
              <% packs.each_with_index do |pack, i| %>
                <%# Le pack du milieu (6 remplissages) est mis en avant.
                    Comme `packs` est trié par nb_remplissages croissant
                    (scope :par_pose), c'est toujours l'index 1. %>
                <div class="pack-card <%= 'featured' if i == 1 %>">
                  <div class="pack-header">
                    <% if i == 1 %>
                      <div class="pack-badge">⭐ Populaire</div>
                    <% end %>
                    <div class="pack-name">
                      <%= pack.nb_remplissages %> remplissages
                    </div>
                    <% if pack.description.present? %>
                      <div class="pack-desc"><%= pack.description %></div>
                    <% end %>
                  </div>
                  <div class="pack-footer">
                    <div class="pack-price"><%= pack.prix_euros.to_i %>€</div>
                    <%# Lien vers le récap d'achat de pack (flux dédié, séparé de la carte cadeau) %>
                    <%= link_to "Choisir", new_pack_orders_path(product_id: pack.id), class: "pack-btn" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# ---- JS — bascule les groupes en fonction de la pill cliquée ---- %>
      <%# Petit script inline, pas besoin de Stimulus pour un toggle aussi local. %>
      <script>
        (function() {
          // Sélectionne toutes les pills de pose et tous les groupes correspondants
          var pills  = document.querySelectorAll('[data-pose-pill]');
          var groups = document.querySelectorAll('[data-pose-group]');
          if (!pills.length || !groups.length) return;

          pills.forEach(function(pill) {
            pill.addEventListener('click', function() {
              var poseId = pill.dataset.posePill;

              // Met à jour visuellement la pill active
              pills.forEach(function(p) { p.classList.remove('active'); });
              pill.classList.add('active');

              // Affiche le groupe correspondant, cache les autres
              groups.forEach(function(g) {
                g.classList.toggle('active', g.dataset.poseGroup === poseId);
              });
            });
          });
        })();
      </script>
    <% end %>

    <%# ---- PRODUITS ROUTINE — données depuis la base ---- %>
    <% if @produits_routine.any? %>
      <div class="sec" id="section-products">
        <div class="s-tag">Routine</div>
        <div class="s-h2">Produits d'entretien</div>
        <div class="s-sub">Sélectionnés pour prolonger la durée de vos extensions.</div>

        <div class="products-grid">
          <% @produits_routine.each do |product| %>
            <div class="product-card">
              <div class="product-img">
                <% if product.photo.attached? %>
                  <%# Photo Active Storage — couvre toute la zone image %>
                  <%= image_tag product.photo,
                                style: "width:100%; height:100%; object-fit:cover; display:block;",
                                alt: product.nom %>
                <% else %>
                  <%# Placeholder SVG générique si pas de photo %>
                  <svg width="40" height="40" viewBox="0 0 40 40" fill="none" opacity="0.3">
                    <circle cx="20" cy="14" r="8" stroke="#2e2926" stroke-width="1.5"/>
                    <path d="M8 36 C8 28 32 28 32 36" stroke="#2e2926" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                <% end %>
              </div>
              <div class="product-body">
                <div class="product-name"><%= product.nom %></div>
                <div class="product-desc"><%= product.description %></div>
                <div class="product-footer">
                  <div class="product-price"><%= product.prix_euros.to_i %>€</div>
                  <%# Achat produit routine — flux démo dédié (statut paye direct, pas de Stripe).
                      Voir OrdersController#new_routine / #create_routine. %>
                  <%= link_to "Ajouter", new_routine_orders_path(product_id: product.id), class: "product-btn" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ---- FOOTER ---- %>
    <div class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-tag">Technicienne du regard · Bordeaux</div>
      <div class="footer-links">
        <%= link_to "FAQ",  faq_path %>
        <%= link_to "Avis", avis_path %>
        <%= link_to "Shop", shop_path %>
        <span>Mentions</span>
        <span>CGV</span>
      </div>
      <div class="footer-copy">© 2026 Biche. · Tous droits réservés</div>
    </div>

  </div>
</div>

<script>
  function scrollToSection(id, btn) {
    document.querySelectorAll('.shop-nav-item').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const target = document.getElementById(id);
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Met à jour l'aperçu de la carte cadeau avec le montant sélectionné
  function selectAmount(el) {
    // Désélectionne tous les montants, active le cliqué
    document.querySelectorAll('.gift-amount').forEach(a => a.classList.remove('selected'));
    el.classList.add('selected');

    // Vide le champ montant libre quand on clique sur un montant prédéfini
    document.getElementById('gift-input-montant').value = '';

    // Met à jour l'aperçu visuel de la carte cadeau
    document.getElementById('gift-preview-amount').textContent = el.textContent;
  }

  // Mise à jour du nom du destinataire en temps réel sur le visuel de la carte
  document.getElementById('gift-input-nom').addEventListener('input', function() {
    const nom = this.value.trim();
    const bloc = document.getElementById('gift-preview-pour');
    const span = document.getElementById('gift-preview-nom');

    if (nom) {
      // Afficher le bloc "Pour Prénom" et mettre à jour le texte
      span.textContent = nom;
      bloc.style.display = 'block';
    } else {
      // Cacher le bloc si le champ est vide
      bloc.style.display = 'none';
    }
  });

  // Mise à jour de l'aperçu en temps réel quand on tape un montant libre
  document.getElementById('gift-input-montant').addEventListener('input', function() {
    const val = this.value.trim();

    // Désélectionne les pills prédéfinies si l'utilisateur tape un montant libre
    document.querySelectorAll('.gift-amount').forEach(a => a.classList.remove('selected'));

    // Met à jour l'aperçu — si le champ est vide on remet le placeholder
    document.getElementById('gift-preview-amount').textContent = val ? val + '€' : '—';
  });

  // Soumettre la carte cadeau — récupère le montant et le nom, puis navigue vers orders#new
  function soumettreCarte(e) {
    e.preventDefault();

    // Chercher le montant : d'abord dans le champ libre, sinon la pill sélectionnée
    const champLibre = document.getElementById('gift-input-montant').value.trim();
    const pillActive = document.querySelector('.gift-amount.selected');

    let montant = 0;
    if (champLibre) {
      montant = parseInt(champLibre, 10);
    } else if (pillActive) {
      // Le texte de la pill est "65€" → on retire le "€"
      montant = parseInt(pillActive.textContent, 10);
    }

    // Validation — montant minimum 10€
    if (!montant || montant < 10) {
      alert("Veuillez sélectionner ou saisir un montant pour la carte cadeau.");
      return;
    }

    // Récupérer le nom du destinataire (optionnel)
    const nom = document.getElementById('gift-input-nom').value.trim();

    // Construire l'URL vers orders#new avec les paramètres
    const params = new URLSearchParams({ montant: montant });
    if (nom) params.append('destinataire_nom', nom);

    window.location.href = "<%= new_order_path %>?" + params.toString();
  }

  // Mise à jour du menu actif au scroll dans le conteneur .phone
  const sections = ['section-gift', 'section-packs', 'section-products'];
  const phone = document.querySelector('.phone');
  phone.addEventListener('scroll', () => {
    let current = 'section-gift';
    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el && el.offsetTop - phone.scrollTop <= 100) current = id;
    });
    document.querySelectorAll('.shop-nav-item').forEach((btn, i) => {
      btn.classList.toggle('active', sections[i] === current);
    });
  });
</script>
