  // Construit le HTML d'une liste de valeurs avec pastille
  function makeValues(arr) {
    return arr.map(v => `<div class="reco-value"><div class="reco-dot"></div>${v}</div>`).join('');
  }

  // Sélectionne un type d'yeux et met à jour la carte de recommandation
  function selectEye(el, type) {
    // Retirer la classe active de toutes les cartes yeux
    document.querySelectorAll('.eye-card').forEach(c => c.classList.remove('active'));
    // Activer la carte cliquée
    el.classList.add('active');

    // Récupérer les données de recommandation
    const r = recos[type];

    // Mettre à jour le texte de la carte résultat
    document.getElementById('result-eye').textContent   = r.eye;
    document.getElementById('result-reco').textContent  = r.reco;
    document.getElementById('reco-forme').innerHTML     = makeValues(r.forme);
    document.getElementById('reco-courbure').innerHTML  = makeValues(r.courbure);
    document.getElementById('reco-longueur').innerHTML  = makeValues(r.longueur);
    document.getElementById('reco-technique').innerHTML = makeValues(r.technique);

    // Scroll vers la section résultat (comportement fluide)
    document.getElementById('result-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>
