<%# Page Morphologie — guide en 3 étapes : techniques / type d'yeux / recommandation %>
<% content_for :title, "Guide morphologie" %>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <% if user_signed_in? %>
          <%= link_to espace_cliente_root_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to "Réserver", new_booking_path, class: "btn-nav" %>
        <div class="burger"><span></span><span></span><span></span></div>
      </div>
    </nav>

    <%# ---- EN-TÊTE ---- %>
    <div class="page-header" style="background: #e8e2d8;">
      <div class="ph-blob"></div>
      <div class="ph-blob-2"></div>
      <div class="ph-tag">Guide</div>
      <h1 class="ph-title">Quelle pose<br>pour vous ?</h1>
      <p class="ph-intro">Découvrez les techniques, analysez votre morphologie et trouvez la pose idéale.</p>
    </div>

    <%# ---- INDICATEUR D'ÉTAPES ---- %>
    <%# Barre de progression des 3 étapes de la page %>
    <div class="steps-indicator">
      <div class="step-item">
        <div class="step-circle active">1</div>
        <div class="step-label active">Les techniques</div>
      </div>
      <div class="step-connector"></div>
      <div class="step-item">
        <div class="step-circle todo">2</div>
        <div class="step-label">Morphologie</div>
      </div>
      <div class="step-connector"></div>
      <div class="step-item">
        <div class="step-circle todo">3</div>
        <div class="step-label">Ma pose</div>
      </div>
    </div>

    <%# ---- ÉTAPE 1 : COMPRENDRE LES TECHNIQUES ---- %>
    <section class="sec">
      <div class="s-num">Étape 1</div>
      <h2 class="s-h2">Comprendre les techniques</h2>
      <p class="s-sub">Toutes les techniques peuvent vous convenir. Le choix dépend avant tout de vos envies et du style recherché.</p>

      <%# Citation de Syam %>
      <div class="techniques-intro">
        <div class="tech-intro-text">« Il n'y a pas de mauvaise technique,<br>il y a celle qui vous ressemble. »</div>
        <div class="tech-intro-sub">Syam adapte chaque pose à vos cils naturels, votre style de vie et vos envies du moment.</div>
      </div>

      <%# Carrousel horizontal des 5 techniques %>
      <div class="techniques-carousel">

        <%# Technique Naturel %>
        <div class="tech-card">
          <div class="tech-card-img ti-naturel">
            <svg width="70" height="42" viewBox="0 0 70 42" fill="none" opacity="0.45">
              <path d="M4 21 C17 10 53 10 66 21" stroke="rgba(46,41,38,0.7)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M4 21 C17 32 53 32 66 21" stroke="rgba(46,41,38,0.7)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <circle cx="35" cy="21" r="8" stroke="rgba(46,41,38,0.6)" stroke-width="1.2" fill="none"/>
              <g stroke="rgba(46,41,38,0.6)" stroke-width="1" stroke-linecap="round">
                <path d="M10 16 L8 7"/><path d="M20 12 L18 4"/><path d="M35 11 L35 3"/><path d="M50 12 L52 4"/><path d="M60 16 L62 7"/>
              </g>
            </svg>
          </div>
          <div class="tech-card-body">
            <div class="tech-card-name">Naturel</div>
            <div class="tech-card-desc">Cil à cil classique. Légèreté et discrétion au quotidien.</div>
            <div class="tech-card-tags">
              <span class="tech-tag">Cil à cil</span>
              <span class="tech-tag">Discret</span>
            </div>
          </div>
        </div>

        <%# Technique Cat eye (sélectionnée par défaut dans la maquette) %>
        <div class="tech-card selected">
          <div class="tech-card-img ti-cat">
            <svg width="70" height="42" viewBox="0 0 70 42" fill="none" opacity="0.45">
              <path d="M4 24 C17 8 50 8 66 16" stroke="rgba(247,245,242,0.8)" stroke-width="2" fill="none" stroke-linecap="round"/>
              <path d="M4 24 C17 36 50 36 66 28" stroke="rgba(247,245,242,0.8)" stroke-width="2" fill="none" stroke-linecap="round"/>
              <circle cx="32" cy="22" r="8" stroke="rgba(247,245,242,0.7)" stroke-width="1.5" fill="none"/>
              <g stroke="rgba(247,245,242,0.7)" stroke-width="1.3" stroke-linecap="round">
                <path d="M8 20 L5 9"/><path d="M18 15 L15 5"/><path d="M32 13 L32 3"/><path d="M48 11 L52 2"/><path d="M60 10 L65 2"/>
              </g>
            </svg>
          </div>
          <div class="tech-card-body">
            <div class="tech-card-name">Cat eye</div>
            <div class="tech-card-desc">Longueur progressive vers l'extérieur. Regard relevé et séducteur.</div>
            <div class="tech-card-tags">
              <span class="tech-tag">Effet chat</span>
              <span class="tech-tag">Sexy</span>
            </div>
          </div>
        </div>

        <%# Technique Doll eye %>
        <div class="tech-card">
          <div class="tech-card-img ti-doll">
            <svg width="70" height="42" viewBox="0 0 70 42" fill="none" opacity="0.45">
              <path d="M4 21 C17 6 53 6 66 21" stroke="rgba(46,41,38,0.7)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M4 21 C17 36 53 36 66 21" stroke="rgba(46,41,38,0.7)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <circle cx="35" cy="21" r="11" stroke="rgba(46,41,38,0.6)" stroke-width="1.5" fill="none"/>
            </svg>
          </div>
          <div class="tech-card-body">
            <div class="tech-card-name">Doll eye</div>
            <div class="tech-card-desc">Longueur au centre. Regard ouvert, grands yeux poupée.</div>
            <div class="tech-card-tags">
              <span class="tech-tag">Ouvert</span>
              <span class="tech-tag">Doux</span>
            </div>
          </div>
        </div>

        <%# Technique Volume intense %>
        <div class="tech-card">
          <div class="tech-card-img ti-intense">
            <svg width="70" height="42" viewBox="0 0 70 42" fill="none" opacity="0.4">
              <path d="M4 21 C17 4 53 4 66 21" stroke="rgba(247,245,242,0.8)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <path d="M4 21 C17 38 53 38 66 21" stroke="rgba(247,245,242,0.8)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <circle cx="35" cy="21" r="10" stroke="rgba(247,245,242,0.7)" stroke-width="1.8" fill="none"/>
              <g stroke="rgba(247,245,242,0.8)" stroke-width="1.8" stroke-linecap="round">
                <path d="M7 14 L3 2"/><path d="M17 8 L13 -2"/><path d="M35 6 L35 -3"/><path d="M53 8 L57 -2"/><path d="M63 14 L67 2"/>
              </g>
            </svg>
          </div>
          <div class="tech-card-body">
            <div class="tech-card-name">Volume intense</div>
            <div class="tech-card-desc">Volume russe. Regard dramatique et spectaculaire.</div>
            <div class="tech-card-tags">
              <span class="tech-tag">Volume russe</span>
              <span class="tech-tag">Intense</span>
            </div>
          </div>
        </div>

        <%# Technique Rehaussement %>
        <div class="tech-card">
          <div class="tech-card-img ti-rehausse">
            <svg width="70" height="42" viewBox="0 0 70 42" fill="none" opacity="0.45">
              <path d="M4 22 C17 14 53 14 66 22" stroke="rgba(46,41,38,0.5)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M4 22 C17 30 53 30 66 22" stroke="rgba(46,41,38,0.5)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <circle cx="35" cy="22" r="7" stroke="rgba(46,41,38,0.4)" stroke-width="1" fill="none"/>
            </svg>
          </div>
          <div class="tech-card-body">
            <div class="tech-card-name">Rehaussement</div>
            <div class="tech-card-desc">Zéro extension. Courbure naturelle des cils pour un effet durable.</div>
            <div class="tech-card-tags">
              <span class="tech-tag">Sans extension</span>
              <span class="tech-tag">Naturel</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <%# ---- ÉTAPE 2 : ANALYSE MORPHOLOGIQUE ---- %>
    <%# La cliente clique sur son type d'yeux → la recommandation se met à jour en JS %>
    <section class="sec sec-alt">
      <div class="s-num">Étape 2</div>
      <h2 class="s-h2">Mon type d'yeux</h2>
      <p class="s-sub">Certaines formes de pose sont plus flatteuses selon votre morphologie. Sélectionnez votre forme d'yeux.</p>

      <div class="eye-grid">

        <%# Yeux en amande — sélectionné par défaut %>
        <div class="eye-card active" onclick="selectEye(this, 'amande')">
          <div class="eye-svg-wrap">
            <svg width="80" height="36" viewBox="0 0 80 36" fill="none">
              <path d="M4 18 C18 6 62 6 76 18" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <path d="M4 18 C18 30 62 30 76 18" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <circle cx="40" cy="18" r="8" stroke="#2e2926" stroke-width="1.4" fill="none"/>
              <circle cx="40" cy="18" r="3" fill="#2e2926"/>
              <circle cx="37" cy="15" r="1.2" fill="#fff"/>
            </svg>
          </div>
          <div class="eye-name">En amande</div>
          <div class="eye-desc">Forme allongée et symétrique</div>
        </div>

        <%# Yeux ronds %>
        <div class="eye-card" onclick="selectEye(this, 'ronds')">
          <div class="eye-svg-wrap">
            <svg width="52" height="44" viewBox="0 0 52 44" fill="none">
              <path d="M4 22 C5 6 47 6 48 22" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <path d="M4 22 C5 38 47 38 48 22" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <circle cx="26" cy="22" r="11" stroke="#2e2926" stroke-width="1.4" fill="none"/>
              <circle cx="26" cy="22" r="4" fill="#2e2926"/>
              <circle cx="23" cy="19" r="1.5" fill="#fff"/>
            </svg>
          </div>
          <div class="eye-name">Ronds</div>
          <div class="eye-desc">Iris très visible, regard expressif</div>
        </div>

        <%# Yeux tombants %>
        <div class="eye-card" onclick="selectEye(this, 'tombants')">
          <div class="eye-svg-wrap">
            <svg width="80" height="36" viewBox="0 0 80 36" fill="none">
              <path d="M4 14 C18 5 58 7 76 20" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <path d="M4 14 C18 26 58 26 76 28" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <circle cx="38" cy="18" r="8" stroke="#2e2926" stroke-width="1.4" fill="none"/>
              <circle cx="38" cy="18" r="3" fill="#2e2926"/>
              <circle cx="35" cy="15" r="1.2" fill="#fff"/>
            </svg>
          </div>
          <div class="eye-name">Tombants</div>
          <div class="eye-desc">Coin externe plus bas</div>
        </div>

        <%# Yeux rapprochés %>
        <div class="eye-card" onclick="selectEye(this, 'rapproches')">
          <div class="eye-svg-wrap">
            <svg width="80" height="36" viewBox="0 0 80 36" fill="none">
              <path d="M4 18 C10 8 28 8 34 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <path d="M4 18 C10 28 28 28 34 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <circle cx="19" cy="18" r="6" stroke="#2e2926" stroke-width="1.2" fill="none"/>
              <circle cx="19" cy="18" r="2.5" fill="#2e2926"/>
              <path d="M44 18 C50 8 68 8 74 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <path d="M44 18 C50 28 68 28 74 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <circle cx="59" cy="18" r="6" stroke="#2e2926" stroke-width="1.2" fill="none"/>
              <circle cx="59" cy="18" r="2.5" fill="#2e2926"/>
              <line x1="35" y1="18" x2="43" y2="18" stroke="#b8a898" stroke-width="1" stroke-dasharray="1.5 1.5"/>
            </svg>
          </div>
          <div class="eye-name">Rapprochés</div>
          <div class="eye-desc">Moins de 1 œil d'écart</div>
        </div>

        <%# Yeux écartés %>
        <div class="eye-card" onclick="selectEye(this, 'ecartes')">
          <div class="eye-svg-wrap">
            <svg width="80" height="36" viewBox="0 0 80 36" fill="none">
              <path d="M2 18 C8 8 22 8 28 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <path d="M2 18 C8 28 22 28 28 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <circle cx="15" cy="18" r="6" stroke="#2e2926" stroke-width="1.2" fill="none"/>
              <circle cx="15" cy="18" r="2.5" fill="#2e2926"/>
              <path d="M50 18 C56 8 70 8 76 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <path d="M50 18 C56 28 70 28 76 18" stroke="#2e2926" stroke-width="1.6" fill="none" stroke-linecap="round"/>
              <circle cx="63" cy="18" r="6" stroke="#2e2926" stroke-width="1.2" fill="none"/>
              <circle cx="63" cy="18" r="2.5" fill="#2e2926"/>
              <line x1="30" y1="18" x2="48" y2="18" stroke="#b8a898" stroke-width="1" stroke-dasharray="2 2"/>
            </svg>
          </div>
          <div class="eye-name">Écartés</div>
          <div class="eye-desc">Plus de 1 œil d'écart</div>
        </div>

        <%# Yeux bridés %>
        <div class="eye-card" onclick="selectEye(this, 'brides')">
          <div class="eye-svg-wrap">
            <svg width="80" height="36" viewBox="0 0 80 36" fill="none">
              <path d="M6 18 C20 11 60 11 74 18" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <path d="M6 18 C20 28 60 28 74 18" stroke="#2e2926" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <path d="M6 18 C8 13 13 15 10 20" stroke="#2e2926" stroke-width="1.2" fill="none" stroke-linecap="round"/>
              <circle cx="40" cy="20" r="4" fill="#2e2926"/>
              <circle cx="37" cy="17" r="1.2" fill="#fff"/>
            </svg>
          </div>
          <div class="eye-name">Bridés</div>
          <div class="eye-desc">Paupière distinctive</div>
        </div>

      </div>
    </section>

    <%# ---- ÉTAPE 3 : RECOMMANDATION PERSONNALISÉE ---- %>
    <%# Le contenu est mis à jour dynamiquement par selectEye() en JS %>
    <section class="sec sec-cream" id="result-section">
      <div class="s-num">Étape 3</div>
      <h2 class="s-h2">Votre recommandation</h2>

      <%# Carte de résultat — fond sombre, mise à jour par JS %>
      <div class="result-card" id="result-card">
        <div class="result-tag">Recommandation Biche.</div>
        <div class="result-eye-name" id="result-eye">Yeux en amande</div>
        <div class="result-reco" id="result-reco">
          La forme en amande est la plus polyvalente. Tous les styles vous vont — jouez sur la courbure et la longueur selon l'effet recherché.
        </div>

        <%# Grille 2x2 des critères de la recommandation %>
        <div class="reco-grid">
          <div class="reco-item">
            <div class="reco-item-label">Forme</div>
            <div class="reco-item-values" id="reco-forme">
              <div class="reco-value"><div class="reco-dot"></div>Cat eye</div>
              <div class="reco-value"><div class="reco-dot"></div>Doll eye</div>
              <div class="reco-value"><div class="reco-dot"></div>Naturel</div>
            </div>
          </div>
          <div class="reco-item">
            <div class="reco-item-label">Courbure</div>
            <div class="reco-item-values" id="reco-courbure">
              <div class="reco-value"><div class="reco-dot"></div>Légère</div>
              <div class="reco-value"><div class="reco-dot"></div>Classique</div>
              <div class="reco-value"><div class="reco-dot"></div>Intense</div>
            </div>
          </div>
          <div class="reco-item">
            <div class="reco-item-label">Longueur</div>
            <div class="reco-item-values" id="reco-longueur">
              <div class="reco-value"><div class="reco-dot"></div>Courte</div>
              <div class="reco-value"><div class="reco-dot"></div>Moyenne</div>
              <div class="reco-value"><div class="reco-dot"></div>Longue</div>
            </div>
          </div>
          <div class="reco-item">
            <div class="reco-item-label">Technique</div>
            <div class="reco-item-values" id="reco-technique">
              <div class="reco-value"><div class="reco-dot"></div>Au choix</div>
            </div>
          </div>
        </div>

        <%# Bouton "Je réserve" qui redirige vers le formulaire %>
        <%= link_to "Je réserve cette pose →", new_booking_path, class: "result-btn" %>
      </div>

      <%# Encadré : le vrai diagnostic se fait lors du RDV %>
      <div class="diagnostic-box">
        <div class="diag-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="9" r="7" stroke="#b8a898" stroke-width="1.3"/>
            <path d="M9 5 L9 10 M9 12 L9 13" stroke="#b8a898" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="diag-title">Diagnostic personnalisé</div>
          <div class="diag-text">Un diagnostic complet sera réalisé lors de votre rendez-vous afin d'adapter parfaitement la prestation à la forme de vos yeux, vos cils naturels et vos envies.</div>
        </div>
      </div>
    </section>

    <%# ---- CONSEILS AVANT POSE ---- %>
    <section class="sec">
      <p class="s-tag">Conseils</p>
      <h2 class="s-h2">Avant votre pose</h2>

      <div class="tip-card">
        <div class="tip-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="9" r="7" stroke="#2e2926" stroke-width="1.2"/>
            <path d="M9 5 L9 10 M9 12 L9 13" stroke="#2e2926" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="tip-title">Arrivez sans mascara</div>
          <div class="tip-text">Yeux propres, sans maquillage sur les cils ni fond de teint. La colle adhère mieux sur un cil sec et propre.</div>
        </div>
      </div>

      <div class="tip-card">
        <div class="tip-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3 10 C6 5 12 5 15 10 C12 15 6 15 3 10Z" stroke="#2e2926" stroke-width="1.2" fill="none"/>
            <circle cx="9" cy="10" r="2.5" fill="#2e2926"/>
          </svg>
        </div>
        <div>
          <div class="tip-title">Préparez vos inspirations</div>
          <div class="tip-text">Des exemples de regards qui vous inspirent aident Syam à cerner votre désir et adapter la pose à la perfection.</div>
        </div>
      </div>

      <div class="tip-card">
        <div class="tip-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="3" y="3" width="12" height="14" rx="2" stroke="#2e2926" stroke-width="1.2"/>
            <path d="M6 8 L12 8 M6 11 L10 11" stroke="#2e2926" stroke-width="1" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="tip-title">Signalez vos allergies</div>
          <div class="tip-text">Tout antécédent d'allergie aux adhésifs doit être mentionné en amont. Un test peut être réalisé si besoin.</div>
        </div>
      </div>
    </section>

    <%# ---- CTA RÉSERVATION ---- %>
    <section class="cta-sec">
      <div class="cta-big">Prête à sublimer<br>votre regard ?</div>
      <p class="cta-sub">Réservez votre soin. Syam adapte chaque pose à votre morphologie lors du rendez-vous.</p>
      <%= link_to "Prendre rendez-vous", new_booking_path, class: "cta-btn" %>
    </section>

    <%# ---- FOOTER ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-tag">Technicienne du regard · Bordeaux</div>
      <div class="footer-links">
        <%= link_to "FAQ",     faq_path %>
        <%= link_to "Avis",    avis_path %>
        <%= link_to "Shop",    shop_path %>
        <%= link_to "Contact", contact_path %>
      </div>
      <div class="footer-copy">© 2026 Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>

<%# ====================================================================
    JavaScript de la page morphologie
    - selectEye(el, type) : met à jour la carte de recommandation selon
      le type d'yeux sélectionné et scroll vers la section résultat.
    ==================================================================== %>
<script>
  // Table de correspondance type d'yeux → recommandation
  const recos = {
    amande: {
      eye: 'Yeux en amande',
      reco: "La forme en amande est la plus polyvalente. Tous les styles vous vont — jouez sur la courbure et la longueur selon l'effet recherché.",
      forme: ['Cat eye', 'Doll eye', 'Naturel'],
      courbure: ['Légère', 'Classique', 'Intense'],
      longueur: ['Courte', 'Moyenne', 'Longue'],
      technique: ['Au choix']
    },
    ronds: {
      eye: 'Yeux ronds',
      reco: "Pour les yeux ronds, privilégiez le cat eye pour allonger le regard et éviter d'accentuer l'ouverture. Longueur sur les côtés.",
      forme: ['Cat eye', 'Effet chat'],
      courbure: ['Légère', 'Classique'],
      longueur: ['Longue en ext.'],
      technique: ['Cil à cil', 'Volume']
    },
