<%# Page Galerie — filtres, collage hero, masonry, avant/après, vidéos, Instagram %>
<% content_for :title, "Galerie" %>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <% if user_signed_in? %>
          <%= link_to espace_cliente_root_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to "Réserver", new_booking_path, class: "btn-nav" %>
        <div class="burger"><span></span><span></span><span></span></div>
      </div>
    </nav>

    <%# ---- EN-TÊTE ---- %>
    <%# Hero — hérite du .page-header global (fond var(--color-nude) = #f5ede2) %>
    <%# pour rester cohérent avec les autres pages du site (prestations, faq…) %>
    <div class="page-header">
      <div class="ph-blob"></div>
      <div class="ph-blob-2"></div>
      <div class="ph-tag">Galerie</div>
      <h1 class="ph-title">Réalisations</h1>
      <p class="ph-intro">Chaque regard est unique. Retrouvez les soins réalisés par Syam au Calao Studio.</p>
    </div>

    <%# ---- FILTRES ---- %>
    <%# Scroll horizontal — chaque pill filtre la grille masonry ou scroll vers une section %>
    <div class="filter-wrap">
      <div class="filter-bar">
        <div class="filter-pill active"        onclick="filterGallery('tout', this)">Tout</div>
        <div class="filter-pill"               onclick="filterGallery('cil-a-cil', this)">Cil à cil</div>
        <div class="filter-pill"               onclick="filterGallery('volume', this)">Volume</div>
        <div class="filter-pill"               onclick="filterGallery('rehaussement', this)">Rehaussement</div>
        <div class="filter-pill"               onclick="filterGallery('sourcils', this)">Sourcils</div>
        <div class="filter-pill"               onclick="filterGallery('avant-apres', this)">Avant / Après</div>
      </div>
    </div>

    <%# ---- GRILLE MASONRY ---- %>
    <%# Chaque item a un data-cat pour le filtre JS %>
    <section class="sec" id="section-tout">
      <p class="s-tag">Réalisations</p>
      <h2 class="s-h2">Le travail de Syam</h2>

      <%# Indicateur du filtre actif (caché par défaut) %>
      <div class="filter-active-info" id="filter-info" style="display:none">
        <div class="filter-active-dot"></div>
        <div class="filter-active-text">Filtré : <b id="filter-label">Tout</b></div>
        <div class="filter-reset" onclick="filterGallery('tout', null)">Tout voir</div>
      </div>

      <div class="masonry" id="masonry-grid">

        <% if @galerie_photos.any? %>
          <%# Boucle dynamique — on exclut les avant/après (affichés dans leur propre section).
              On utilise each_with_index pour pouvoir prioriser le chargement des 4 premières
              photos (celles visibles immédiatement à l'écran). %>
          <% @galerie_photos.reject { |p| p.categorie == 'avant-apres' }.each_with_index do |photo, idx| %>
            <%# data-cat : utilisé par le filtre JS pour afficher/masquer les items %>
            <div class="masonry-item <%= photo.taille %>" data-cat="<%= photo.categorie %>">

              <%# Photo uploadée via Active Storage, ou fond dégradé de fallback %>
              <% if photo.image.attached? %>
                <%# Optimisations chargement :
                    - Les 4 premières photos (au-dessus de la ligne de flottaison) :
                      loading="eager" + fetchpriority="high" → le navigateur les charge en
                      priorité absolue dès le HTML reçu, sans attendre la fin du parsing.
                    - Les suivantes : loading="lazy" → ne sont téléchargées que quand
                      elles approchent du viewport (économise la bande passante mobile).
                    - decoding="async" : le décodage de l'image ne bloque pas le rendu
                      du reste de la page. %>
                <%= image_tag photo.image,
                              class: "masonry-photo",
                              alt: photo.legende,
                              loading: idx < 4 ? "eager" : "lazy",
                              fetchpriority: idx < 4 ? "high" : "auto",
                              decoding: "async" %>
              <% else %>
                <%# Fond dégradé placeholder si aucune image n'a été uploadée %>
                <div class="masonry-bg-placeholder"></div>
              <% end %>

              <%# Légende superposée sur la photo %>
              <div class="masonry-legend">
                <div class="masonry-legend-text"><%= photo.legende %></div>
                <% if photo.legende_sub.present? %>
                  <div class="masonry-legend-sub"><%= photo.legende_sub %></div>
                <% end %>
              </div>

            </div>
          <% end %>

        <% else %>
          <%# Fallback si la galerie est vide — afficher un message discret %>
          <div style="grid-column: 1 / -1; padding: 40px 0; text-align: center; color: var(--color-muted); font-size: 14px;">
            La galerie sera bientôt disponible.
          </div>
        <% end %>

      </div>

      <%# Bouton "Voir plus" — visible uniquement si plus de 8 photos (géré par JS) %>
      <div id="voir-plus-wrap" style="text-align:center; padding: 8px 0 24px; display:none;">
        <button onclick="voirPlusPhotos()" id="btn-voir-plus"
                style="padding: 11px 28px; border-radius: 30px; border: 1px solid var(--color-dark); background: transparent; color: var(--color-dark); font-size: 11px; font-family: inherit; letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer;">
          Voir plus
        </button>
      </div>

    </section>

    <%# ---- AVANT / APRÈS ---- %>
    <%# Carrousel horizontal — id ciblé par le filtre JS %>
    <section class="sec sec-alt" id="section-avant-apres">
      <p class="s-tag">Transformations</p>
      <h2 class="s-h2">Avant / Après</h2>
      <p class="s-sub">Le résultat parle de lui-même.</p>

      <div class="avap-wrap">

        <%# Récupérer uniquement les photos de catégorie avant-apres ayant les deux images %>
        <% avap_photos = @galerie_photos.select { |p| p.categorie == 'avant-apres' && p.image.attached? && p.image_apres.attached? } %>

        <% if avap_photos.any? %>
          <%# Boucle dynamique sur les vrais avant/après uploadés par Syam %>
          <% avap_photos.each do |photo| %>
            <div class="avap-card">
              <div class="avap-split">
                <%# Côté gauche : photo avant
                    loading="lazy" + decoding="async" : la section avant/après est sous la
                    fold, on laisse le navigateur charger en différé pour ne pas concurrencer
                    les images du masonry visibles dès l'arrivée sur la page. %>
                <div class="avap-side before" style="padding:0; overflow:hidden;">
                  <%= image_tag photo.image,
                                alt: "Avant — #{photo.legende}",
                                loading: "lazy",
                                decoding: "async",
                                style: "width:100%; height:100%; object-fit:cover; display:block;" %>
                  <div class="avap-label before">Avant</div>
                </div>
                <%# Côté droit : photo après — mêmes attributs de chargement différé %>
                <div class="avap-side after" style="padding:0; overflow:hidden;">
                  <%= image_tag photo.image_apres,
                                alt: "Après — #{photo.legende}",
                                loading: "lazy",
                                decoding: "async",
                                style: "width:100%; height:100%; object-fit:cover; display:block;" %>
                  <div class="avap-label after">Après</div>
                </div>
              </div>
              <div class="avap-footer">
                <div class="avap-name"><%= photo.legende %></div>
                <% if photo.legende_sub.present? %>
                  <div class="avap-meta"><%= photo.legende_sub %></div>
                <% end %>
              </div>
            </div>
          <% end %>

        <% else %>
          <%# Fallback SVG — affiché tant qu'aucun avant/après n'a été ajouté via l'admin %>
          <div class="avap-card">
            <div class="avap-split">
              <div class="avap-side before">
                <svg width="44" height="26" viewBox="0 0 50 30" fill="none">
                  <path d="M3 15 C12 7 38 7 47 15" stroke="rgba(46,41,38,0.35)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                  <path d="M3 15 C12 23 38 23 47 15" stroke="rgba(46,41,38,0.35)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                  <circle cx="25" cy="15" r="5" stroke="rgba(46,41,38,0.3)" stroke-width="1" fill="none"/>
                </svg>
                <div class="avap-label before">Avant</div>
              </div>
              <div class="avap-side after">
                <svg width="44" height="26" viewBox="0 0 50 30" fill="none">
                  <path d="M3 15 C12 3 38 3 47 15" stroke="rgba(247,245,242,0.75)" stroke-width="2" fill="none" stroke-linecap="round"/>
                  <g stroke="rgba(247,245,242,0.8)" stroke-width="1.2" stroke-linecap="round">
                    <path d="M10 12 L7 3"/><path d="M18 9 L16 1"/><path d="M25 8 L25 0"/><path d="M32 9 L34 1"/><path d="M40 12 L43 3"/>
                  </g>
                </svg>
                <div class="avap-label after">Après</div>
              </div>
            </div>
            <div class="avap-footer">
              <div class="avap-name">Cil à cil naturel</div>
              <div class="avap-meta">Bientôt disponible</div>
            </div>
          </div>
        <% end %>

      </div>
    </section>

    <%# ---- VIDÉOS ---- %>
    <%# Section visible uniquement si Syam a ajouté au moins une vidéo %>
    <% if @videos.any? %>
      <section class="sec" id="section-videos">
        <p class="s-tag">Vidéos</p>
        <h2 class="s-h2">En mouvement</h2>

        <%# Scroll horizontal — même pattern que les best-sellers du shop %>
        <div class="video-row">
          <% @videos.each do |video| %>
            <%#
              Chaque card est un lien vers Instagram (nouvel onglet).
              La miniature uploadée par Syam sert de thumbnail.
            %>
            <a href="<%= video.url %>"
               target="_blank"
               rel="noopener noreferrer"
               class="video-card">

              <%# Thumbnail / player — si fichier vidéo uploadé : player au survol
                  Sinon : miniature statique avec bouton play %>
              <div class="video-thumb" style="background:var(--color-sand);">

                <% if video.video_file.attached? %>
                  <%#
                    Fichier vidéo disponible → élément <video>
                    - poster : miniature affichée avant le play
                    - muted + playsinline : requis pour l'autoplay sur mobile
                    - loop : boucle infinie pendant le survol
                    - preload="none" : ne charge pas la vidéo au chargement de la page
                    Le JS déclenche play() au mouseenter et pause() + currentTime=0 au mouseleave
                  %>
                  <video class="video-player"
                         src="<%= url_for(video.video_file) %>"
                         <% if video.miniature.attached? %>poster="<%= url_for(video.miniature) %>"<% end %>
                         muted
                         loop
                         playsinline
                         preload="none"
                         style="width:100%; height:100%; object-fit:cover; display:block;">
                  </video>

                  <%# Overlay bouton play — caché quand la vidéo joue (JS toggle la classe) %>
                  <div class="video-play-overlay">
                    <div style="width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.92); display:flex; align-items:center; justify-content:center;">
                      <svg width="14" height="16" viewBox="0 0 14 16" fill="none">
                        <path d="M2 1.5 L13 8 L2 14.5 Z" fill="#2e2926"/>
                      </svg>
                    </div>
                  </div>

                <% else %>
                  <%# Pas de fichier vidéo — miniature statique + bouton play décoratif %>
                  <% if video.miniature.attached? %>
                    <%# Miniatures vidéos en bas de page → chargement différé pour
                        prioriser ce qui est immédiatement visible (masonry du haut). %>
                    <%= image_tag video.miniature,
                                  style: "width:100%; height:100%; object-fit:cover; display:block;",
                                  alt: video.titre,
                                  loading: "lazy",
                                  decoding: "async" %>
                  <% else %>
                    <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:32px;">🎬</div>
                  <% end %>

                  <%# Bouton play centré %>
                  <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.92); display:flex; align-items:center; justify-content:center;">
                    <svg width="14" height="16" viewBox="0 0 14 16" fill="none">
                      <path d="M2 1.5 L13 8 L2 14.5 Z" fill="#2e2926"/>
                    </svg>
                  </div>
                <% end %>

                <%# Dégradé bas + logo Instagram — toujours visible %>
                <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 50%); pointer-events:none;"></div>
                <div style="position:absolute; top:10px; right:10px; pointer-events:none;">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <rect x="1.5" y="1.5" width="15" height="15" rx="4.5" stroke="rgba(255,255,255,0.9)" stroke-width="1.5"/>
                    <circle cx="9" cy="9" r="3.5" stroke="rgba(255,255,255,0.9)" stroke-width="1.5"/>
                    <circle cx="13" cy="5" r="1" fill="rgba(255,255,255,0.9)"/>
                  </svg>
                </div>
              </div>

              <%# Titre et tag sous la miniature %>
              <div class="video-meta">
                <div class="video-name"><%= video.titre %></div>
                <% if video.tag.present? %>
                  <div class="video-tag"><%= video.tag.humanize %></div>
                <% end %>
              </div>

            </a>
          <% end %>
        </div>
      </section>
    <% end %>

    <%# ---- DERNIÈRE VIDÉO (player natif, plus d'embed TikTok) ---- %>
    <%# Affichée juste avant la section Instagram.
        Le partial ne rend rien si aucun fichier MP4 n'est attaché. %>
    <%= render "shared/video_player", video_setting: @latest_video %>

    <%# ---- INSTAGRAM ---- %>
    <%# Carte invitation : icône avec dégradé brand Instagram + titre + handle + CTA.
        Pas de grille (on ne peut pas afficher les photos Instagram sans API).
        Visuel pensé "premium" : carte centrée avec ombre douce, icône large,
        bouton avec le dégradé officiel Instagram pour ramener l'œil. %>
    <div class="insta-sec">
      <div class="insta-card">

        <%# Cercle décoratif contenant le logo Instagram en SVG.
            Le dégradé est appliqué via .insta-icon-circle (CSS). %>
        <div class="insta-icon-circle">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="2" width="20" height="20" rx="5" stroke="#fff" stroke-width="1.8"/>
            <circle cx="12" cy="12" r="4.5" stroke="#fff" stroke-width="1.8"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="#fff"/>
          </svg>
        </div>

        <div class="insta-title">Suivez l'atelier</div>
        <p class="insta-sub">Découvrez les dernières réalisations,<br>conseils et coulisses sur Instagram.</p>
        <div class="insta-handle">@atelier_b.iche</div>

        <%# Bouton CTA — couleurs du brand Instagram appliquées en CSS %>
        <a href="https://www.instagram.com/atelier_b.iche/"
           target="_blank"
           rel="noopener noreferrer"
           class="insta-btn">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="1.5" y="1.5" width="11" height="11" rx="3" stroke="#fff" stroke-width="1.3"/>
            <circle cx="7" cy="7" r="2.5" stroke="#fff" stroke-width="1.3"/>
            <circle cx="10" cy="4" r="0.7" fill="#fff"/>
          </svg>
          Voir sur Instagram
        </a>

      </div>
    </div>

    <%# ---- FOOTER ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-tag">Technicienne du regard · Bordeaux</div>
      <div class="footer-links">
        <%= link_to "FAQ",     faq_path %>
        <%= link_to "Avis",    avis_path %>
        <%= link_to "Shop",    shop_path %>
        <%= link_to "Contact", contact_path %>
      </div>
      <div class="footer-copy">© 2026 Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>

<%# ====================================================================
    JavaScript de la galerie
    - filterGallery(cat, pillEl) : filtre les items masonry par catégorie
      et scroll vers la bonne section selon le filtre sélectionné.
    ==================================================================== %>
<script>
  // ---- PREVIEW VIDÉO AU SURVOL ----
  // Pour chaque card avec un élément <video>, on lance la lecture au mouseenter
  // et on met en pause + remet à zéro au mouseleave
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.video-thumb').forEach(function(thumb) {
      const video = thumb.querySelector('video.video-player');
      if (!video) return; // pas de fichier vidéo sur cette card

      // Survol entrant → lancer la vidéo
      thumb.addEventListener('mouseenter', function() {
        video.play();
        thumb.classList.add('playing'); // masque l'overlay play
      });

      // Survol sortant → mettre en pause et revenir au début
      thumb.addEventListener('mouseleave', function() {
        video.pause();
        video.currentTime = 0;
        thumb.classList.remove('playing'); // réaffiche l'overlay play
      });
    });
  });

  // Nombre de photos affichées au départ avant le bouton "Voir plus"
  const LIMITE_PHOTOS = 8;

  // Indique si l'utilisateur a déjà cliqué sur "Voir plus"
  // → si oui, on ne réapplique pas la limite quand le filtre revient à "tout"
  let toutVisible = false;

  // Au chargement de la page : masquer les photos au-delà de LIMITE_PHOTOS
  document.addEventListener('DOMContentLoaded', function() {
    appliquerLimite();
  });

  // Masque les items au-delà de la limite et affiche/cache le bouton "Voir plus"
  function appliquerLimite() {
    if (toutVisible) return; // déjà tout affiché, ne rien faire

    const items = Array.from(document.querySelectorAll('.masonry-item'));
    const wrap  = document.getElementById('voir-plus-wrap');

    items.forEach(function(item, i) {
      // On masque les items à partir de la 9e photo
      item.style.display = i < LIMITE_PHOTOS ? 'block' : 'none';
    });

    // Afficher le bouton uniquement s'il y a plus de LIMITE_PHOTOS photos
    if (wrap) wrap.style.display = items.length > LIMITE_PHOTOS ? 'block' : 'none';
  }

  // Clic sur "Voir plus" : afficher toutes les photos et cacher le bouton
  function voirPlusPhotos() {
    toutVisible = true;

    document.querySelectorAll('.masonry-item').forEach(function(item) {
      item.style.display = 'block';
    });

    const wrap = document.getElementById('voir-plus-wrap');
    if (wrap) wrap.style.display = 'none';
  }

  // Correspondance catégorie → section cible du scroll
  const categories = {
    'tout':         { label: 'Tout',         section: 'section-tout' },
    'cil-a-cil':    { label: 'Cil à cil',    section: 'section-tout' },
    'volume':       { label: 'Volume',        section: 'section-tout' },
    'rehaussement': { label: 'Rehaussement',  section: 'section-tout' },
    'sourcils':     { label: 'Sourcils',      section: 'section-tout' },
    'avant-apres':  { label: 'Avant / Après', section: 'section-avant-apres' }
  };

  function filterGallery(cat, pillEl) {
    // Mettre à jour la pill active
    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    if (pillEl) {
      pillEl.classList.add('active');
    } else {
      document.querySelector('.filter-pill').classList.add('active');
    }

    const info  = document.getElementById('filter-info');
    const label = document.getElementById('filter-label');
    const items = document.querySelectorAll('.masonry-item');
    const wrap  = document.getElementById('voir-plus-wrap');

    if (cat === 'tout') {
      // Réafficher tous les items puis réappliquer la limite si "Voir plus" pas encore cliqué
      items.forEach(item => { item.style.display = 'block'; });
      info.style.display = 'none';
      appliquerLimite(); // remet la limite si toutVisible === false
      document.getElementById('section-tout').scrollIntoView({ behavior: 'smooth', block: 'start' });

    } else if (cat === 'avant-apres') {
      // Masquer la grille, scroller vers la section avant/après
      items.forEach(item => { item.style.display = 'none'; });
      if (wrap) wrap.style.display = 'none'; // cacher aussi le bouton "voir plus"
      info.style.display = 'flex';
      label.textContent = categories[cat].label;
      document.getElementById('section-avant-apres').scrollIntoView({ behavior: 'smooth', block: 'start' });

    } else {
      // Filtrer par catégorie — on montre TOUT ce qui correspond, sans limite
      items.forEach(item => {
        item.style.display = (item.dataset.cat === cat) ? 'block' : 'none';
      });
      if (wrap) wrap.style.display = 'none'; // pas de "voir plus" quand on filtre
      info.style.display = 'flex';
      label.textContent = categories[cat].label;
      document.getElementById('section-tout').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
</script>
