<%# Page "À propos" — portrait de Syam, histoire, valeurs, parcours, studio %>
<% content_for :title, "À propos" %>

<div class="wrap">
  <div class="phone">

    <%# ---- NAVIGATION ---- %>
    <nav class="nav">
      <%= link_to "Biche.", root_path, class: "logo-mini" %>
      <div class="nav-right">
        <% if user_signed_in? %>
          <%# Icône compte pour les clientes connectées %>
          <%= link_to espace_cliente_root_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% else %>
          <%# Icône compte pour visiteurs non connectés — redirige vers le login %>
          <%= link_to new_user_session_path do %>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="6.5" r="3" stroke="#2e2926" stroke-width="1.3"/>
              <path d="M2.5 16c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to "Réserver", new_booking_path, class: "btn-nav" %>
        <div class="burger"><span></span><span></span><span></span></div>
      </div>
    </nav>

    <%# ---- HERO PORTRAIT ---- %>
    <%# Zone d'accueil avec la photo de Syam et des blobs décoratifs %>
    <div class="portrait-hero">
      <div class="ph-bg-blob"></div>
      <div class="ph-bg-blob-2"></div>
      <div class="portrait-wrap">
        <%# Photo de Syam — placeholder SVG remplacé par une vraie photo plus tard %>
        <div class="portrait-img">
          <svg width="80" height="100" viewBox="0 0 80 100" fill="none" opacity="0.3">
            <ellipse cx="40" cy="32" rx="18" ry="20" stroke="#fff" stroke-width="1.5"/>
            <path d="M10 90 C10 65 70 65 70 90" stroke="#fff" stroke-width="1.5" fill="none"/>
          </svg>
        </div>
        <div class="portrait-sup">Fondatrice</div>
        <div class="portrait-name">Syam</div>
        <div class="portrait-role">
          Technicienne du regard sur mesure<br>
          Bordeaux · Calao Studio
        </div>
      </div>
    </div>

    <%# ---- MON HISTOIRE ---- %>
    <section class="sec">
      <p class="s-tag">Mon histoire</p>
      <h2 class="s-h2">Une passion pour le regard</h2>
      <p class="body-text">
        Technicienne du regard installée à Bordeaux, je travaille au sein du Calao Studio,
        un espace que j'aime profondément : ancré dans la création, loin des codes des instituts traditionnels.
      </p>
      <p class="body-text">
        Ma philosophie tient en une phrase : chaque regard est unique, chaque pose doit l'être aussi.
        Je prends le temps d'observer, d'écouter et d'adapter chaque soin à votre morphologie et à vos envies du moment.
      </p>

      <%# Citation mise en avant %>
      <blockquote class="quote-block">
        <p class="quote-text">« Du naturel au plus intense, je crée le regard qui vous ressemble. »</p>
      </blockquote>

      <p class="body-text">
        Que vous veniez pour la première fois ou que vous soyez une fidèle de l'atelier,
        chaque rendez-vous est pour moi un moment de confiance que je prends très à cœur.
      </p>
    </section>

    <%# ---- VALEURS ---- %>
    <%# Grille 2x2 des 4 valeurs fondamentales de Syam %>
    <section class="sec sec-cream">
      <p class="s-tag">Mon approche</p>
      <h2 class="s-h2">Ce qui guide mon travail</h2>
      <div class="values-grid">

        <%# Valeur 1 : Précision %>
        <div class="value-card">
          <div class="value-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M3 11 C6 5 16 5 19 11 C16 17 6 17 3 11Z" stroke="#2e2926" stroke-width="1.3"/>
              <circle cx="11" cy="11" r="3.5" fill="#2e2926"/>
            </svg>
          </div>
          <div class="value-name">Précision</div>
          <div class="value-desc">Chaque cil, chaque courbe, posé avec soin</div>
        </div>

        <%# Valeur 2 : Écoute %>
        <div class="value-card">
          <div class="value-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 3 C6 3 3 6 3 11 C3 16 6 19 11 19 C16 19 19 16 19 11" stroke="#2e2926" stroke-width="1.3" fill="none"/>
              <path d="M14 8 L11 11 L9 9" stroke="#2e2926" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="value-name">Écoute</div>
          <div class="value-desc">Votre envie guide chaque décision</div>
        </div>

        <%# Valeur 3 : Qualité %>
        <div class="value-card">
          <div class="value-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 4 L13.5 9 L19 9.7 L15 13.5 L16 19 L11 16.4 L6 19 L7 13.5 L3 9.7 L8.5 9 Z" stroke="#2e2926" stroke-width="1.3" fill="none"/>
            </svg>
          </div>
          <div class="value-name">Qualité</div>
          <div class="value-desc">Produits premium, résultats durables</div>
        </div>

        <%# Valeur 4 : Bienveillance %>
        <div class="value-card">
          <div class="value-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 19 L4 12 C4 8.7 6.7 6 10 6 C10.7 6 11.3 6.1 11 6.3 C10.7 6.1 11.3 6 12 6 C15.3 6 18 8.7 18 12 Z" stroke="#2e2926" stroke-width="1.3" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="value-name">Bienveillance</div>
          <div class="value-desc">Un espace doux, sans jugement</div>
        </div>

      </div>
    </section>

    <%# ---- PARCOURS / TIMELINE ---- %>
    <%# Historique de formation et d'expérience de Syam %>
    <section class="sec">
      <p class="s-tag">Parcours</p>
      <h2 class="s-h2">Mon expertise</h2>
      <div class="timeline">

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-year">Formation initiale</div>
          <div class="timeline-title">Certification extensions de cils</div>
          <div class="timeline-desc">Formation professionnelle aux techniques cil à cil et volume, obtention de la certification.</div>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-year">Perfectionnement</div>
          <div class="timeline-title">Volume russe & techniques avancées</div>
          <div class="timeline-desc">Maîtrise du volume russe, des poses personnalisées et des techniques morphologiques.</div>
        </div>

        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-year">Aujourd'hui</div>
          <div class="timeline-title">Atelier Biche. au Calao Studio</div>
          <div class="timeline-desc">Installée au cœur de Bordeaux, au sein du Calao Studio, pour un espace unique mêlant art et beauté.</div>
        </div>

        <%# Étape future — pastille de couleur différente pour indiquer "à venir" %>
        <div class="timeline-item">
          <div class="timeline-dot" style="background: #f0e8dc; border-color: #b8a898;"></div>
          <div class="timeline-year">Bientôt</div>
          <div class="timeline-title">Extension aux sourcils</div>
          <div class="timeline-desc">Prochaine étape : intégrer les soins sourcils à l'offre de l'atelier.</div>
        </div>

      </div>
    </section>

    <%# ---- LE STUDIO ---- %>
    <%# Présentation du Calao Studio où travaille Syam %>
    <section class="sec sec-alt">
      <p class="s-tag">Le lieu</p>
      <h2 class="s-h2">Calao Studio</h2>
      <p class="body-text">
        Le Calao Studio est un espace singulier : un salon de tatouage et d'art qui accueille l'atelier Biche.
        Je travaille dans cet environnement créatif et bienveillant, loin des instituts classiques.
      </p>

      <%# Image principale du studio (placeholder) %>
      <div class="studio-img">
        <svg width="80" height="60" viewBox="0 0 80 60" fill="none" opacity="0.3">
          <rect x="10" y="10" width="60" height="40" rx="4" stroke="#fff" stroke-width="1.5"/>
          <path d="M10 22 L70 22" stroke="#fff" stroke-width="1"/>
          <circle cx="55" cy="16" r="3" fill="#fff" opacity="0.5"/>
          <rect x="20" y="30" width="15" height="20" rx="2" fill="#fff" opacity="0.2"/>
          <rect x="44" y="34" width="18" height="10" rx="2" fill="#fff" opacity="0.2"/>
        </svg>
      </div>

      <%# Mini-galerie 2 photos du studio %>
      <div class="studio-grid">
        <div class="studio-item"></div>
        <div class="studio-item studio-item-2"></div>
      </div>

      <%# Carte d'adresse %>
      <div class="studio-addr">
        <div class="studio-pin">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 1C5 1 2.5 3.5 2.5 6.5c0 4 5.5 8.5 5.5 8.5s5.5-4.5 5.5-8.5C13.5 3.5 11 1 8 1z" stroke="#fff" stroke-width="1.2" fill="none"/>
            <circle cx="8" cy="6.5" r="2" fill="#fff"/>
          </svg>
        </div>
        <div>
          <div class="studio-addr-name">Calao Studio</div>
          <div class="studio-addr-text">37 Rue Lachassaigne<br>33000 Bordeaux</div>
        </div>
      </div>

      <%# Bouton Google Maps (lien externe à brancher quand disponible) %>
      <a href="#" class="maps-btn">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 1C4.2 1 2 3.2 2 6c0 3.5 5 7 5 7s5-3.5 5-7c0-2.8-2.2-5-5-5z" stroke="#2e2926" stroke-width="1.2" fill="none"/>
          <circle cx="7" cy="6" r="1.5" fill="#2e2926"/>
        </svg>
        Voir sur Google Maps
      </a>
    </section>

    <%# ---- CTA RÉSERVATION ---- %>
    <section class="cta-sec">
      <div class="cta-big">Prête à prendre<br>rendez-vous ?</div>
      <p class="cta-sub">Réservez votre soin en ligne et confiez votre regard à Syam.</p>
      <%= link_to "Réserver maintenant", new_booking_path, class: "cta-btn" %>
    </section>

    <%# ---- FOOTER ---- %>
    <footer class="footer">
      <div class="footer-logo">Biche.</div>
      <div class="footer-tag">Technicienne du regard · Bordeaux</div>
      <div class="footer-links">
        <%= link_to "FAQ",          faq_path %>
        <%= link_to "Avis",         avis_path %>
        <%= link_to "Shop",         shop_path %>
        <%= link_to "Contact",      contact_path %>
      </div>
      <div class="footer-copy">© 2026 Biche. · Tous droits réservés</div>
    </footer>

  </div>
</div>
